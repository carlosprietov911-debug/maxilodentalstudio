---
import "../styles/global.css";
import BaseHead from "../components/BaseHead.astro";

interface Props {
  title?: string;
  descripcion?: string;
  image?: string;
}

const {
  title = "Maxilodental Studio",
  descripcion = "Clínica odontológica. Agenda tu cita por WhatsApp.",
  image = "/og.jpg",
} = Astro.props as Props;
---

<!doctype html>
<html lang="es-CO">
  <head>
    <BaseHead title={title} descripcion={descripcion} image={image} />
  </head>

  <body>
    <slot />
  </body>
</html>