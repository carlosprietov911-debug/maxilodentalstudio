---
import { Image } from "astro:assets";
import caso1 from "../../assets/casos/caso1.jpeg";
import antes from "../../assets/casos/antes.jpeg";
import despues from "../../assets/casos/despues.jpeg";
import Layout from "../../layouts/Layout.astro";

const VIDEO_SRC = "/videos/caso1.mp4";
---

<Layout>
<section>
  <div class="mx-auto max-w-3xl px-6 pt-12 pb-28">

    <!-- Volver -->
    <a href="/casosclinicos"
      class="inline-flex items-center gap-1.5 text-sm text-[#aaa] hover:text-[#2AA7B0] transition-colors mb-10"
    >
      ← Casos clínicos
    </a>

    <!-- HERO -->
    <div class="mb-12">
      <span class="inline-block rounded-full border border-[#2AA7B0]/30 px-3 py-1 text-[11px] font-semibold uppercase tracking-widest text-[#2AA7B0]">
        Implantes
      </span>

      <h1 class="mt-5 text-[2.4rem] md:text-[3rem] font-light leading-[1.08] tracking-[-0.03em] text-[#1a1a1a]">
        Rehabilitación completa
        <span class="block font-semibold">con implantes dentales</span>
      </h1>

      <p class="mt-5 text-[#7a7a7a] leading-relaxed max-w-lg">
        Recuperación de función y estética mediante una rehabilitación fija sobre implantes.
      </p>
    </div>

    <div class="mb-12 h-px bg-[#ebebeb]"></div>

    <!-- IMAGEN PRINCIPAL -->
    <div class="mb-14 overflow-hidden rounded-2xl">
      <Image
        src={caso1}
        alt="Resultado del tratamiento"
        width={900}
        height={480}
        class="w-full h-80 object-cover"
      />
    </div>

    <!-- TEXTO -->
    <div class="mb-14">
      <h2 class="text-[11px] font-semibold uppercase tracking-widest text-[#aaa] mb-4">
        Tratamiento realizado
      </h2>
      <p class="text-[#4a4a4a] leading-relaxed">
        Colocación de implantes y rehabilitación fija híbrida con restauración funcional y estética.
      </p>
    </div>

    <div class="mb-14 h-px bg-[#ebebeb]"></div>

    <!-- ========================= -->
    <!-- CARRUSEL CLÍNICO PREMIUM -->
    <!-- ========================= -->
    <div class="mb-14">
      <h2 class="text-[11px] font-semibold uppercase tracking-widest text-[#aaa] mb-8">
        Evolución del caso
      </h2>

      <div class="flex gap-6 overflow-x-auto snap-x snap-mandatory scroll-smooth pb-4">

        <!-- ANTES -->
        <div class="min-w-65 snap-center">
          <div class="overflow-hidden rounded-xl">
            <Image
              src={antes}
              alt="Antes"
              width={500}
              height={300}
              class="h-55 w-full object-cover grayscale"
            />
          </div>
          <p class="mt-3 text-[11px] font-semibold uppercase tracking-widest text-[#bbb]">
            Antes
          </p>
          <p class="mt-1.5 text-sm text-[#7a7a7a]">
            Pérdida dental avanzada y deterioro funcional.
          </p>
        </div>

        <!-- VIDEO -->
        <div class="min-w-65 snap-center">
          <div class="overflow-hidden rounded-xl bg-black">
            <video
              id="casoVideo"
              src={VIDEO_SRC}
              controls
              playsinline
              class="h-55 w-full object-cover"
            />
          </div>
          <p class="mt-3 text-[11px] font-semibold uppercase tracking-widest text-[#2AA7B0]">
            Procedimiento
          </p>
          <p class="mt-1.5 text-sm text-[#7a7a7a]">
            Registro del tratamiento clínico realizado.
          </p>
        </div>

        <!-- DESPUÉS -->
        <div class="min-w-65 snap-center">
          <div class="overflow-hidden rounded-xl">
            <Image
              src={despues}
              alt="Después"
              width={500}
              height={300}
              class="h-55 w-full object-cover"
            />
          </div>
          <p class="mt-3 text-[11px] font-semibold uppercase tracking-widest text-[#2AA7B0]">
            Después
          </p>
          <p class="mt-1.5 text-sm text-[#7a7a7a]">
            Rehabilitación completa con estética natural.
          </p>
        </div>

      </div>
    </div>

    <div class="mb-14 h-px bg-[#ebebeb]"></div>

    <!-- CTA -->
    <div class="flex flex-col items-start gap-4 md:flex-row md:items-center md:justify-between">
      <div>
        <p class="text-base font-semibold text-[#1a1a1a]">
          ¿Te gustaría un resultado similar?
        </p>
        <p class="mt-1 text-sm text-[#7a7a7a]">
          Evaluación personalizada de tu caso.
        </p>
      </div>

      <a
        href="https://wa.link/u29whe"
        target="_blank"
        class="inline-flex items-center justify-center rounded-full bg-[#1a1a1a] px-6 py-3 text-sm text-white hover:bg-[#333] transition"
      >
        Escribir por WhatsApp →
      </a>
    </div>

  </div>
</section>
</Layout>

<!-- ========================= -->
<!-- AUTOPLAY INTELIGENTE VIDEO -->
<!-- ========================= -->
<script>
  const video = document.getElementById("casoVideo") as HTMLVideoElement | null;

  if (video) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            video.play().catch(() => {});
          } else {
            video.pause();
          }
        });
      },
      { threshold: 0.6 }
    );

    observer.observe(video);
  }
</script>