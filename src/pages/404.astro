---
import Layout from "../layouts/Layout.astro";

const WHATSAPP_URL = "https://wa.link/u29whe";
const imageSrc = "/img/404-logo.png";
---

<Layout title="404 | Maxilodental Studio" descripcion="Página no encontrada">
  <section class="not-found">
    <div class="bg-orb orb-1" aria-hidden="true"></div>
    <div class="bg-orb orb-2" aria-hidden="true"></div>
    <div class="bg-grid" aria-hidden="true"></div>

    <div class="container">
      <article class="card enter">
        <div class="content">
          <div class="badge">
            <span class="badge-dot"></span>
            Error 404
          </div>

          <p class="eyebrow">Maxilodental Studio</p>

          <h1 class="title">
            <span class="title-code">404</span>
            <span class="title-text">La página que buscas no existe</span>
          </h1>

          <p class="description">
            Puede que el enlace esté roto, la página haya sido movida o simplemente
            la dirección no sea correcta. Puedes volver al inicio o escribirnos por
            WhatsApp y te ayudamos de inmediato.
          </p>

          <div class="actions">
            <a class="btn btn-primary" href="/">
              <span>Volver al inicio</span>
            </a>

            <a
              class="btn btn-secondary"
              href={WHATSAPP_URL}
              target="_blank"
              rel="noreferrer"
            >
              <span>Agendar por WhatsApp</span>
            </a>
          </div>

          <nav class="quick-links" aria-label="Enlaces rápidos">
            <a href="/#servicios">Servicios</a>
            <span>•</span>
            <a href="/#reseñas">Reseñas</a>
            <span>•</span>
            <a href="/#contacto">Contacto</a>
          </nav>
        </div>

        <div class="visual">
          <div class="visual-card floaty">
            <div class="visual-glow" aria-hidden="true"></div>

            <img
              src={imageSrc}
              alt="Ilustración de la clínica Maxilodental Studio"
              class="visual-image"
              loading="lazy"
            />
          </div>

          <div class="tip-box">
            <span class="tip-label">Sugerencia</span>
            <p class="tip-text">
              Si llegaste aquí desde un enlace antiguo, escríbenos y te enviamos la
              ruta correcta.
            </p>
          </div>
        </div>
      </article>
    </div>
  </section>
</Layout>

<style>
  :root {
    --bg: #f8fcfd;
    --surface: rgba(255, 255, 255, 0.72);
    --surface-strong: rgba(255, 255, 255, 0.88);
    --stroke: rgba(12, 23, 31, 0.08);
    --text: #10232b;
    --text-soft: rgba(16, 35, 43, 0.72);
    --text-muted: rgba(16, 35, 43, 0.58);
    --brand: #4db4bf;
    --brand-soft: #d8f7fa;
    --dark: #0f1f27;
    --shadow: 0 24px 70px rgba(15, 31, 39, 0.12);
    --shadow-soft: 0 16px 34px rgba(15, 31, 39, 0.08);
    --radius-xl: 32px;
    --radius-lg: 22px;
    --radius-md: 16px;
    --radius-pill: 999px;
  }

  .not-found {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
    display: grid;
    place-items: center;
    padding: 40px 16px;
    background:
      radial-gradient(circle at top left, rgba(77, 180, 191, 0.18), transparent 32%),
      radial-gradient(circle at 85% 20%, rgba(216, 247, 250, 0.95), transparent 28%),
      linear-gradient(180deg, #ffffff 0%, var(--bg) 100%);
    isolation: isolate;
  }

  .container {
    width: 100%;
    max-width: 1180px;
    position: relative;
    z-index: 2;
  }

  .bg-orb {
    position: absolute;
    border-radius: 999px;
    filter: blur(50px);
    opacity: 0.75;
    z-index: 0;
  }

  .orb-1 {
    width: 320px;
    height: 320px;
    background: rgba(77, 180, 191, 0.26);
    top: 6%;
    left: -80px;
  }

  .orb-2 {
    width: 280px;
    height: 280px;
    background: rgba(216, 247, 250, 0.95);
    right: -60px;
    bottom: 8%;
  }

  .bg-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(16, 35, 43, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(16, 35, 43, 0.03) 1px, transparent 1px);
    background-size: 34px 34px;
    mask-image: radial-gradient(circle at center, black 45%, transparent 85%);
    z-index: 0;
    pointer-events: none;
  }

  .card {
    position: relative;
    display: grid;
    gap: 28px;
    padding: 24px;
    border: 1px solid var(--stroke);
    border-radius: var(--radius-xl);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.92), rgba(255, 255, 255, 0.70));
    box-shadow: var(--shadow);
    backdrop-filter: blur(16px);
    overflow: hidden;
  }

  .card::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(135deg, rgba(77, 180, 191, 0.14), transparent 35%),
      linear-gradient(300deg, rgba(216, 247, 250, 0.55), transparent 40%);
    pointer-events: none;
  }

  @media (min-width: 980px) {
    .card {
      grid-template-columns: 1.1fr 0.9fr;
      align-items: center;
      padding: 42px;
      gap: 42px;
    }
  }

  .content,
  .visual {
    position: relative;
    z-index: 1;
  }

  .badge {
    width: fit-content;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 9px 14px;
    border-radius: var(--radius-pill);
    background: var(--surface-strong);
    border: 1px solid rgba(16, 35, 43, 0.08);
    box-shadow: 0 10px 24px rgba(15, 31, 39, 0.06);
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--text);
  }

  .badge-dot {
    width: 9px;
    height: 9px;
    border-radius: 999px;
    background: var(--brand);
    box-shadow: 0 0 0 6px rgba(77, 180, 191, 0.18);
  }

  .eyebrow {
    margin: 18px 0 0;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .title {
    margin: 14px 0 0;
    display: grid;
    gap: 10px;
    line-height: 1;
  }

  .title-code {
    font-size: clamp(56px, 8vw, 104px);
    font-weight: 900;
    letter-spacing: -0.05em;
    color: var(--dark);
    text-shadow: 0 10px 25px rgba(15, 31, 39, 0.08);
  }

  .title-text {
    max-width: 12ch;
    font-size: clamp(28px, 3.4vw, 46px);
    line-height: 1.08;
    font-weight: 850;
    letter-spacing: -0.03em;
    color: var(--text);
  }

  .description {
    margin: 18px 0 0;
    max-width: 58ch;
    font-size: 16px;
    line-height: 1.8;
    color: var(--text-soft);
  }

  .actions {
    margin-top: 26px;
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
  }

  .btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 50px;
    padding: 0 18px;
    border-radius: 16px;
    font-size: 14px;
    font-weight: 800;
    text-decoration: none;
    transition:
      transform 180ms ease,
      box-shadow 180ms ease,
      border-color 180ms ease,
      background 180ms ease,
      color 180ms ease;
    border: 1px solid transparent;
    box-shadow: var(--shadow-soft);
  }

  .btn:hover {
    transform: translateY(-2px);
  }

  .btn-primary {
    background: linear-gradient(135deg, #11232c 0%, #1c3640 100%);
    color: white;
    border-color: rgba(15, 31, 39, 0.18);
  }

  .btn-primary:hover {
    box-shadow: 0 18px 34px rgba(15, 31, 39, 0.18);
  }

  .btn-secondary {
    background: rgba(255, 255, 255, 0.78);
    color: var(--text);
    border-color: rgba(16, 35, 43, 0.1);
  }

  .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.96);
    box-shadow: 0 18px 34px rgba(15, 31, 39, 0.10);
  }

  .quick-links {
    margin-top: 22px;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: center;
    color: var(--text-muted);
    font-size: 14px;
  }

  .quick-links a {
    color: inherit;
    text-decoration: none;
    font-weight: 600;
    position: relative;
  }

  .quick-links a::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -4px;
    width: 100%;
    height: 1px;
    background: currentColor;
    opacity: 0.45;
    transition: opacity 160ms ease, transform 160ms ease;
    transform: scaleX(0.95);
    transform-origin: left;
  }

  .quick-links a:hover::after {
    opacity: 1;
    transform: scaleX(1);
  }

  .quick-links span {
    opacity: 0.4;
  }

  .visual {
    display: grid;
    gap: 16px;
    justify-items: center;
  }

  .visual-card {
    position: relative;
    width: min(420px, 100%);
    min-height: 320px;
    display: grid;
    place-items: center;
    border-radius: 28px;
    border: 1px solid rgba(16, 35, 43, 0.08);
    background:
      linear-gradient(180deg, rgba(255,255,255,0.92), rgba(255,255,255,0.72));
    box-shadow: var(--shadow-soft);
    overflow: hidden;
    padding: 24px;
  }

  .visual-glow {
    position: absolute;
    inset: auto;
    width: 240px;
    height: 240px;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(77, 180, 191, 0.28), transparent 70%);
    filter: blur(20px);
    z-index: 0;
  }

  .visual-image {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 290px;
    height: auto;
    max-height: 280px;
    object-fit: contain;
    display: block;
    filter: drop-shadow(0 18px 28px rgba(15, 31, 39, 0.14));
  }

  .tip-box {
    width: min(420px, 100%);
    padding: 16px 18px;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.76);
    border: 1px solid rgba(16, 35, 43, 0.08);
    box-shadow: var(--shadow-soft);
  }

  .tip-label {
    display: inline-block;
    margin-bottom: 8px;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--brand);
  }

  .tip-text {
    margin: 0;
    color: var(--text-soft);
    font-size: 14px;
    line-height: 1.65;
    font-weight: 600;
  }

  .enter {
    animation: enter 0.65s ease-out both;
  }

  .floaty {
    animation: float 6s ease-in-out infinite;
  }

  @keyframes enter {
    from {
      opacity: 0;
      transform: translateY(18px) scale(0.985);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @keyframes float {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-8px);
    }
  }

  @media (max-width: 640px) {
    .not-found {
      padding: 20px 12px;
    }

    .card {
      padding: 18px;
      border-radius: 24px;
    }

    .title-text {
      max-width: 100%;
    }

    .description {
      font-size: 15px;
      line-height: 1.7;
    }

    .actions {
      flex-direction: column;
    }

    .actions .btn {
      width: 100%;
    }

    .visual-card {
      min-height: 260px;
      padding: 18px;
    }

    .visual-image {
      max-width: 230px;
      max-height: 220px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .enter,
    .floaty,
    .btn {
      animation: none !important;
      transition: none !important;
    }

    .btn:hover {
      transform: none;
    }
  }
</style>