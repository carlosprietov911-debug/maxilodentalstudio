---
import Layout from "../layouts/Layout.astro";

const WHATSAPP_URL = "https://wa.link/u29whe";
const imageSrc = "/img/404-logo.png";
---

<Layout title="404 | Maxilodental Studio" descripcion="Página no encontrada">
  <section class="wrap">
    <div class="shell">
      <div class="card enter">
        <!-- Col izquierda -->
        <div class="copy">
          <div class="pill">
            <span class="dot" aria-hidden="true"></span>
            Error 404
          </div>

          <h1 class="title">
            <span class="code">404</span>
            <span class="text">Página no encontrada</span>
          </h1>

          <p class="desc">
            La URL que buscaste no existe o fue movida. Puedes volver al inicio o
            escribirnos y te ayudamos a agendar una cita.
          </p>

          <div class="actions">
            <a class="btn primary" href="/">Volver al inicio</a>

            <a
              class="btn ghost"
              href={WHATSAPP_URL}
              target="_blank"
              rel="noreferrer"
            >
              Agendar por WhatsApp
            </a>
          </div>

          <div class="links">
            <a href="/#servicios">Servicios</a>
            <span>•</span>
            <a href="/#reseñas">Reseñas</a>
            <span>•</span>
            <a href="/#contacto">Contacto</a>
          </div>
        </div>

        <!-- Col derecha -->
        <div class="art">
          <div class="artFrame floaty">
            <img
              src={imageSrc}
              alt="Ilustración de la clínica"
              loading="lazy"
              class="artImg"
            />
            <div class="shine" aria-hidden="true"></div>
          </div>

          <div class="tag" aria-hidden="true">
            <span class="tagStrong">Tip</span>
            <span class="tagText">Si llegaste aquí por error, escríbenos 👍</span>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Layout base */
  .wrap {
    min-height: calc(100vh - 80px);
    padding: 48px 16px;
    display: grid;
    place-items: center;
    background:
      radial-gradient(1200px 600px at 15% 25%, rgba(77, 180, 191, 0.35), transparent 55%),
      radial-gradient(900px 500px at 85% 35%, rgba(219, 251, 255, 0.85), transparent 55%),
      radial-gradient(900px 500px at 65% 85%, rgba(77, 180, 191, 0.18), transparent 55%),
      #ffffff;
  }

  .shell {
    width: 100%;
    max-width: 1100px;
  }

  .card {
    position: relative;
    overflow: hidden;
    border-radius: 28px;
    padding: 28px;
    background: linear-gradient(140deg, rgba(77, 180, 191, 0.35), rgba(219, 251, 255, 0.55));
    box-shadow: 0 18px 45px rgba(2, 20, 25, 0.10);
    border: 1px solid rgba(2, 20, 25, 0.08);
    display: grid;
    gap: 26px;
  }

  @media (min-width: 980px) {
    .card {
      grid-template-columns: 1.15fr 0.85fr;
      padding: 40px;
      gap: 34px;
      align-items: center;
    }
  }

  /* Col izquierda */
  .copy {
    color: rgba(12, 23, 31, 0.92);
  }

  .pill {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: rgba(255, 255, 255, 0.65);
    border: 1px solid rgba(2, 20, 25, 0.10);
    border-radius: 999px;
    padding: 8px 12px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: rgba(12, 23, 31, 0.85);
    box-shadow: 0 0 0 4px rgba(12, 23, 31, 0.10);
  }

  .title {
    margin: 14px 0 0;
    line-height: 1.05;
    display: grid;
    gap: 10px;
  }

  .code {
    font-size: clamp(44px, 6vw, 72px);
    font-weight: 900;
    letter-spacing: -0.03em;
    color: rgba(12, 23, 31, 0.92);
  }

  .text {
    font-size: clamp(26px, 3.2vw, 40px);
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .desc {
    margin: 14px 0 0;
    font-size: 16px;
    line-height: 1.7;
    max-width: 58ch;
    color: rgba(12, 23, 31, 0.78);
  }

  .actions {
    margin-top: 20px;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 12px 16px;
    border-radius: 14px;
    font-weight: 800;
    font-size: 14px;
    text-decoration: none;
    border: 1px solid rgba(2, 20, 25, 0.12);
    transition: transform 180ms ease, box-shadow 180ms ease, background 180ms ease, opacity 180ms ease;
    will-change: transform;
  }

  .btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 25px rgba(2, 20, 25, 0.12);
  }

  .primary {
    background: rgba(12, 23, 31, 0.95);
    color: white;
    border-color: rgba(12, 23, 31, 0.2);
  }

  .ghost {
    background: rgba(255, 255, 255, 0.65);
    color: rgba(12, 23, 31, 0.92);
  }

  .links {
    margin-top: 18px;
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    align-items: center;
    font-size: 14px;
    color: rgba(12, 23, 31, 0.72);
  }

  .links a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 4px;
    transition: opacity 160ms ease;
  }

  .links a:hover {
    opacity: 0.8;
  }

  .links span {
    opacity: 0.45;
  }

  /* Col derecha */
  .art {
    display: grid;
    justify-items: center;
    gap: 14px;
  }

  .artFrame {
    position: relative;
    width: min(380px, 100%);
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid rgba(2, 20, 25, 0.12);
    box-shadow: 0 18px 35px rgba(2, 20, 25, 0.10);
    padding: 18px;
    overflow: hidden;
  }

  /* ✅ Imagen más chica y sin recorte */
  .artImg {
    width: 100%;
    height: auto;
    max-height: 260px;
    object-fit: contain;
    display: block;
    filter: drop-shadow(0 10px 14px rgba(2, 20, 25, 0.12));
  }

  .shine {
    pointer-events: none;
    position: absolute;
    inset: -40%;
    background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.75), transparent 55%);
    opacity: 0.65;
    transform: rotate(12deg);
  }

  .tag {
    width: min(380px, 100%);
    border-radius: 16px;
    padding: 12px 14px;
    background: rgba(12, 23, 31, 0.06);
    border: 1px solid rgba(2, 20, 25, 0.10);
    color: rgba(12, 23, 31, 0.78);
    display: flex;
    gap: 10px;
    align-items: baseline;
  }

  .tagStrong {
    font-weight: 900;
  }

  .tagText {
    font-weight: 600;
  }

  /* Animaciones */
  .enter {
    animation: enter 520ms ease-out both;
  }

  @keyframes enter {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .floaty {
    animation: float 6.5s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50%      { transform: translateY(-10px); }
  }

  /* Reduce motion */
  @media (prefers-reduced-motion: reduce) {
    .enter, .floaty, .btn { animation: none !important; transition: none !important; }
    .btn:hover { transform: none; box-shadow: none; }
  }
</style>