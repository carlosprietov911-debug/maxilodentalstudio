---
import { Picture } from "astro:assets";
import type { ImageMetadata } from "astro";

type HeroCard = {
  label: string;
  text: string;
};

type HeroCTA = {
  label: string;
  href: string;
};

type HeroFloatingCard = {
  label: string;
  text: string;
};

type HeroSlide = {
  image: ImageMetadata | string;
  alt: string;
  title: string;
  titleHighlight: string;
  description: string;
  primaryCta?: HeroCTA;
  secondaryCta?: HeroCTA;
  floatingCard?: HeroFloatingCard;
  cards?: HeroCard[];
  tags?: string[];
};

type Props = {
  slides?: HeroSlide[];
  autoplay?: boolean;
  interval?: number;
};

const {
  slides = [],
  autoplay = true,
  interval = 6000,
} = Astro.props as Props;

const hasMultipleSlides = slides.length > 1;
---

<section
  class="relative overflow-hidden"
  data-hero-slider
  data-autoplay={autoplay ? "true" : "false"}
  data-interval={String(interval)}
>
  <div class="mx-auto max-w-7xl px-6 pt-2 pb-12 md:pt-4 md:pb-14 lg:px-10 lg:pt-4 lg:pb-16">
    <div class="overflow-hidden">
      <div
        class="flex transition-transform duration-700 ease-[cubic-bezier(0.22,1,0.36,1)] will-change-transform"
        data-slider-track
      >
        {slides.map((slide, index) => (
          <article class="min-w-full">
            <div class="grid items-center gap-8 lg:grid-cols-[1.02fr_.98fr] lg:gap-12">
              <!-- Imagen primero en móvil -->
              <div class="group order-1 relative flex justify-center lg:order-2 lg:justify-end">
                <div class="relative w-full max-w-152">
                  <div class="absolute inset-x-[7%] top-[8%] -z-20 h-[80%] rounded-full bg-[radial-gradient(circle,rgba(77,180,191,0.22)_0%,rgba(77,180,191,0.08)_44%,transparent_74%)] blur-[46px]"></div>
                  <div class="absolute inset-x-[14%] bottom-[5%] -z-10 h-[16%] rounded-full bg-[radial-gradient(ellipse_at_center,rgba(26,24,24,0.24)_0%,rgba(26,24,24,0.10)_52%,transparent_80%)] blur-2xl"></div>

                  {typeof slide.image === "string" ? (
                    <img
                      src={slide.image}
                      alt={slide.alt}
                      loading={index === 0 ? "eager" : "lazy"}
                      fetchpriority={index === 0 ? "high" : "auto"}
                      class="relative z-10 h-auto w-full object-contain mask-fade-bottom transition duration-500 ease-out group-hover:-translate-y-0.5 group-hover:scale-[1.01] filter-[drop-shadow(0_18px_30px_rgba(18,16,16,0.18))_drop-shadow(0_42px_72px_rgba(18,16,16,0.14))]"
                    />
                  ) : (
                    <Picture
                      src={slide.image}
                      alt={slide.alt}
                      formats={["avif", "webp"]}
                      fallbackFormat="webp"
                      quality="mid"
                      priority={index === 0}
                      widths={[420, 560, 760, 960, 1200]}
                      sizes="(max-width: 640px) 92vw, (max-width: 1024px) 78vw, 608px"
                      class="relative z-10 h-auto w-full object-contain mask-fade-bottom transition duration-500 ease-out group-hover:-translate-y-0.5 group-hover:scale-[1.01] filter-[drop-shadow(0_18px_30px_rgba(18,16,16,0.18))_drop-shadow(0_42px_72px_rgba(18,16,16,0.14))]"
                    />
                  )}

                  {slide.floatingCard && (
                    <div class="absolute bottom-4 left-1/2 z-20 hidden w-fit -translate-x-1/2 rounded-2xl border border-white/80 bg-white/88 px-4 py-3 shadow-[0_14px_35px_rgba(0,0,0,0.10)] backdrop-blur-md md:flex lg:left-6 lg:translate-x-0">
                      <div class="flex items-center gap-3">
                        <span class="h-2.5 w-2.5 rounded-full bg-[#4db4bf]"></span>
                        <div>
                          <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-[#6e6161]">
                            {slide.floatingCard.label}
                          </p>
                          <p class="text-sm font-medium text-[#2b2020]">
                            {slide.floatingCard.text}
                          </p>
                        </div>
                      </div>
                    </div>
                  )}
                </div>
              </div>

              <!-- Texto -->
              <div class="order-2 max-w-2xl lg:order-1">
                <h1 class="max-w-xl text-[2.35rem] font-light leading-[0.98] tracking-[-0.04em] text-[#1f2024] md:text-5xl lg:text-[4.1rem]">
                  {slide.title}
                  <span class="block font-medium text-[#241717]">
                    {slide.titleHighlight}
                  </span>
                </h1>

                <p class="mt-5 max-w-xl text-[1.02rem] leading-relaxed text-[#5c5f66] md:text-[1.14rem] lg:text-[1.2rem]">
                  {slide.description}
                </p>

                <div class="mt-7 flex flex-col gap-3 sm:flex-row">
                  {slide.primaryCta && (
                    <a
                      href={slide.primaryCta.href}
                      class="inline-flex w-fit items-center justify-center rounded-full bg-[#241717] px-7 py-3.5 text-base font-semibold text-white shadow-[0_12px_28px_rgba(36,23,23,0.16)] transition duration-300 hover:-translate-y-0.5 hover:bg-[#352525]"
                    >
                      {slide.primaryCta.label}
                    </a>
                  )}

                  {slide.secondaryCta && (
                    <a
                      href={slide.secondaryCta.href}
                      class="inline-flex w-fit items-center justify-center rounded-full border border-[#dddede] bg-white/92 px-7 py-3.5 text-base font-medium text-[#2f3035] transition duration-300 hover:-translate-y-0.5 hover:bg-[#faf9f9]"
                    >
                      {slide.secondaryCta.label}
                    </a>
                  )}
                </div>

                {slide.cards && slide.cards.length > 0 && (
                  <div class="mt-8 grid gap-3 sm:grid-cols-3">
                    {slide.cards.map((card) => (
                      <div class="rounded-2xl border border-white/80 bg-white/80 p-4 shadow-[0_10px_24px_rgba(0,0,0,0.05)] backdrop-blur-sm">
                        <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-[#8a7a7a]">
                          {card.label}
                        </p>
                        <p class="mt-2 text-sm leading-relaxed text-[#403636]">
                          {card.text}
                        </p>
                      </div>
                    ))}
                  </div>
                )}

                {slide.tags && slide.tags.length > 0 && (
                  <div class="mt-7 flex flex-wrap items-center gap-x-5 gap-y-3 text-sm font-medium text-[#605a5a] md:text-[15px]">
                    {slide.tags.map((tag, tagIndex) => (
                      <Fragment>
                        {tagIndex > 0 && (
                          <span class="h-1.5 w-1.5 rounded-full bg-[#d7c2c2]"></span>
                        )}
                        <span>{tag}</span>
                      </Fragment>
                    ))}
                  </div>
                )}
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>

    {hasMultipleSlides && (
      <div class="mt-8 flex items-center justify-center gap-3">
        <button
          type="button"
          aria-label="Slide anterior"
          data-slider-prev
          class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-[#e5dede] bg-white/90 text-[#2f3035] shadow-[0_8px_22px_rgba(0,0,0,0.06)] transition duration-300 hover:-translate-y-0.5 hover:bg-white"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 18l-6-6 6-6" />
          </svg>
        </button>

        <div class="flex items-center gap-2">
          {slides.map((_, index) => (
            <button
              type="button"
              aria-label={`Ir al slide ${index + 1}`}
              aria-current={index === 0 ? "true" : "false"}
              data-slider-dot
              class:list={[
                "h-2.5 rounded-full transition-all duration-300",
                index === 0 ? "w-7 bg-[#241717]" : "w-2.5 bg-[#d8cccc]",
              ]}
            ></button>
          ))}
        </div>

        <button
          type="button"
          aria-label="Siguiente slide"
          data-slider-next
          class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-[#e5dede] bg-white/90 text-[#2f3035] shadow-[0_8px_22px_rgba(0,0,0,0.06)] transition duration-300 hover:-translate-y-0.5 hover:bg-white"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 6l6 6-6 6" />
          </svg>
        </button>
      </div>
    )}
  </div>
</section>

<script>
  const sliders = document.querySelectorAll<HTMLElement>("[data-hero-slider]");

  sliders.forEach((root) => {
    const track = root.querySelector<HTMLElement>("[data-slider-track]");
    if (!track) return;

    const slideElements = Array.from(track.children);
    if (slideElements.length <= 1) return;

    const prevBtn = root.querySelector<HTMLButtonElement>("[data-slider-prev]");
    const nextBtn = root.querySelector<HTMLButtonElement>("[data-slider-next]");
    const dots = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-slider-dot]"));

    const autoplayEnabled = root.dataset.autoplay === "true";
    const intervalValue = Number(root.dataset.interval ?? "6000");
    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    ).matches;

    let current = 0;
    let timer: ReturnType<typeof setInterval> | null = null;

    const update = () => {
      track.style.transform = `translate3d(-${current * 100}%, 0, 0)`;

      dots.forEach((dot, index) => {
        const isActive = index === current;
        dot.setAttribute("aria-current", isActive ? "true" : "false");
        dot.classList.toggle("w-7", isActive);
        dot.classList.toggle("bg-[#241717]", isActive);
        dot.classList.toggle("w-2.5", !isActive);
        dot.classList.toggle("bg-[#d8cccc]", !isActive);
      });
    };

    const goTo = (index: number) => {
      current = (index + slideElements.length) % slideElements.length;
      update();
    };

    const stopAutoplay = () => {
      if (timer !== null) {
        clearInterval(timer);
        timer = null;
      }
    };

    const startAutoplay = () => {
      if (!autoplayEnabled || prefersReducedMotion) return;
      stopAutoplay();
      timer = setInterval(() => goTo(current + 1), intervalValue);
    };

    prevBtn?.addEventListener("click", () => { goTo(current - 1); startAutoplay(); });
    nextBtn?.addEventListener("click", () => { goTo(current + 1); startAutoplay(); });

    dots.forEach((dot, index) => {
      dot.addEventListener("click", () => { goTo(index); startAutoplay(); });
    });

    root.addEventListener("mouseenter", stopAutoplay);
    root.addEventListener("mouseleave", startAutoplay);
    root.addEventListener("focusin", stopAutoplay);
    root.addEventListener("focusout", startAutoplay);

    document.addEventListener("visibilitychange", () => {
      if (document.hidden) stopAutoplay();
      else startAutoplay();
    });

    update();
    startAutoplay();
  });
</script>