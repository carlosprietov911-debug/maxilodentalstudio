---
import type { HTMLTag } from "astro/types";

type Props<Tag extends HTMLTag = "h1"> = {
  as?: Tag;
  class?: string;
  [key: string]: unknown;
};

const variantClasses = {
  h1: "text-4xl font-bold",
  h2: "text-3xl font-bold",
  h3: "text-2xl font-semibold",
  p: "text-base",
} as const;

const { as: Tag = "h1", class: className, ...rest } = Astro.props as Props;

const variant = Tag as keyof typeof variantClasses;
const variantClass = variantClasses[variant] ?? "text-base";
const classes = [variantClass, className].filter(Boolean).join(" ");
---

<Tag class={classes} {...rest}>
  <slot />
</Tag>