---
import whatsappIcon from "../../assets/whatsapp.png?url";

type Props = {
  href?: string;
  label?: string;
  text?: string;
};

const {
  href = "https://wa.link/u29whe",
  label = "Abrir WhatsApp para agendar cita",
  text = "Agenda tu cita por WhatsApp",
} = Astro.props as Props;
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  aria-label={label}
  class="group fixed z-50
         right-4 bottom-[calc(1rem+env(safe-area-inset-bottom))]
         md:right-7 md:bottom-8
         xl:right-10 xl:bottom-10"
>
  <span
    class="relative inline-flex items-center gap-3 overflow-hidden rounded-full
           border border-white/70 bg-white/84
           pl-3 pr-5 py-3
           shadow-[0_18px_42px_rgba(0,0,0,0.12)]
           backdrop-blur-md
           transition duration-300
           hover:-translate-y-1
           hover:shadow-[0_24px_56px_rgba(0,0,0,0.16)]
           active:scale-[0.98]
           md:gap-4 md:pl-3.5 md:pr-6 md:py-3.5
           xl:pl-4 xl:pr-7 xl:py-4"
  >
    <!-- halo -->
    <span
      aria-hidden="true"
      class="absolute inset-0 bg-[linear-gradient(180deg,rgba(255,255,255,0.18),rgba(255,255,255,0.04))]"
    ></span>

    <!-- icono -->
    <span class="relative inline-flex shrink-0 items-center justify-center">
      <span
        aria-hidden="true"
        class="absolute inset-0 scale-110 rounded-full bg-[#25D366]/20 blur-md motion-safe:animate-pulse"
      ></span>

      <span
        class="relative inline-flex h-14 w-14 items-center justify-center rounded-full
               bg-[#25D366]
               shadow-[0_14px_30px_rgba(37,211,102,0.30)]
               ring-1 ring-black/8
               md:h-[4.1rem] md:w-[4.1rem]
               xl:h-[4.5rem] xl:w-[4.5rem]"
      >
        <img
          src={whatsappIcon}
          alt=""
          aria-hidden="true"
          class="h-8 w-8 object-contain md:h-9 md:w-9 xl:h-10 xl:w-10"
          loading="lazy"
        />
      </span>
    </span>

    <!-- texto -->
    <span class="relative hidden min-w-0 md:block">
      <span class="block text-[10px] font-semibold uppercase tracking-[0.22em] text-[#8a756f] xl:text-[11px]">
        Atención inmediata
      </span>
      <span class="mt-1 block text-sm font-semibold leading-none text-[#171717] xl:text-base">
        {text}
      </span>
    </span>

    <!-- versión móvil -->
    <span class="relative pr-1 text-sm font-semibold text-[#171717] md:hidden">
      WhatsApp
    </span>
  </span>
</a>