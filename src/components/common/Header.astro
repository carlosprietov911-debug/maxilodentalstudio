---
import logoDesktop from "../../assets/Logotipo.svg?url";
import logoMobile from "../../assets/logo_tioM.svg?url";
---

<header class="relative z-[120] mx-auto max-w-7xl px-4 pt-4 sm:px-6 sm:pt-5 lg:px-15 lg:py-10">
  <div class="flex min-h-[72px] items-center justify-between gap-4 md:min-h-[84px] lg:min-h-[110px]">
    <!-- Logo -->
    <a href="/" class="flex shrink-0 items-center">
      <!-- Logo móvil -->
      <img
        src={logoMobile}
        alt=""
        width="300"
        height="160"
        class="block h-24 w-auto sm:h-28 lg:hidden"
        loading="eager"
        decoding="async"
      />

      <!-- Logo desktop -->
      <img
        src={logoDesktop}
        alt=""
        width="300"
        height="160"
        class="hidden h-30 w-auto lg:block"
        loading="eager"
        decoding="async"
      />
    </a>

    <!-- Menú escritorio -->
    <nav class="hidden items-center gap-10 font-semibold text-[#111] lg:flex lg:text-lg">
      <a
        href="/"
        class="inline-flex h-10 items-center underline-offset-4 transition hover:text-[#2AA7B0] hover:underline"
      >
        Inicio
      </a>

      <a
        href="/#nosotros-equipo"
        class="inline-flex h-10 items-center underline-offset-4 transition hover:text-[#2AA7B0] hover:underline"
      >
        Nosotros
      </a>

      <a
        href="/servicios"
        class="inline-flex h-10 items-center underline-offset-4 transition hover:text-[#2AA7B0] hover:underline"
      >
        Servicios
      </a>

      <a
        href="/pacientes"
        class="inline-flex h-10 items-center underline-offset-4 transition hover:text-[#2AA7B0] hover:underline"
      >
        Pacientes
      </a>

      <a
        href="/contacto"
        class="ml-2 inline-flex h-10 items-center justify-center text-[#2AA7B0] transition hover:text-[#111]"
      >
        Contacto
      </a>
    </nav>

    <!-- Menú móvil -->
    <details class="group lg:hidden">
      <summary
        class="relative z-[220] flex h-12 w-12 cursor-pointer list-none items-center justify-center rounded-full border border-black/8 bg-white text-[#111] shadow-sm marker:content-none"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5 transition duration-300 group-open:rotate-90"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </summary>

      <!-- Fondo -->
      <div class="fixed inset-0 z-[200] bg-black/20 backdrop-blur-[2px]"></div>

      <!-- Panel -->
      <div class="fixed left-4 right-4 top-24 z-[210] overflow-hidden rounded-[24px] border border-black/5 bg-white p-3 shadow-[0_18px_50px_rgba(0,0,0,0.14)]">
        <nav class="flex flex-col gap-1 text-[#111] font-semibold">
          <a
            href="/"
            class="rounded-[18px] px-4 py-3 transition hover:bg-[#f7f4f2] hover:text-[#2AA7B0]"
          >
            Inicio
          </a>

          <a
            href="/#nosotros-equipo"
            class="rounded-[18px] px-4 py-3 transition hover:bg-[#f7f4f2] hover:text-[#2AA7B0]"
          >
            Nosotros
          </a>

          <a
            href="/servicios"
            class="rounded-[18px] px-4 py-3 transition hover:bg-[#f7f4f2] hover:text-[#2AA7B0]"
          >
            Servicios
          </a>

          <a
            href="/pacientes"
            class="rounded-[18px] px-4 py-3 transition hover:bg-[#f7f4f2] hover:text-[#2AA7B0]"
          >
            Pacientes
          </a>

          <div class="my-1 h-px bg-[#efe6e2]"></div>

          <a
            href="/contacto"
            class="mt-1 inline-flex items-center justify-center rounded-full bg-[#2AA7B0] px-5 py-3 text-white transition hover:brightness-110"
          >
            Contacto
          </a>
        </nav>
      </div>
    </details>
  </div>

  <!-- barra móvil inferior -->
  <div class="mt-3 lg:hidden">
    <div class="flex items-center gap-2 overflow-x-auto rounded-full border border-white/80 bg-white/82 p-2 shadow-[0_10px_24px_rgba(20,20,20,0.06)] backdrop-blur">
      <a
        href="/contacto"
        class="inline-flex shrink-0 items-center justify-center rounded-full bg-[#171717] px-4 py-2.5 text-[13px] font-semibold text-white"
      >
        Contacto
      </a>

      <a
        href="#ubicacion"
        class="inline-flex shrink-0 items-center justify-center rounded-full border border-[#e7dcd7] bg-[#fcfbfb] px-4 py-2.5 text-[13px] font-semibold text-[#171717]"
      >
        Ubicación
      </a>

      <a
        href="https://wa.link/u29whe"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex shrink-0 items-center justify-center rounded-full border border-[#d9efe0] bg-[#effaf3] px-4 py-2.5 text-[13px] font-semibold text-[#15803d]"
      >
        WhatsApp
      </a>
    </div>
  </div>
</header>