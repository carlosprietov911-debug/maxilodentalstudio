---
import { getImage } from "astro:assets";
import _equipoImg from "../../../assets/equipo.png";

const equipoImg = await getImage({
  src: _equipoImg,
  format: "webp",
  widths: [340, 480, 640, 750],
  sizes: "(max-width: 640px) 85vw, (max-width: 768px) 90vw, (max-width: 1024px) 620px, 760px",
  quality: 78,
});


const WHATSAPP_URL = "https://wa.link/u29whe";

const puntos = [
  "Orientación clara",
  "Respuesta rápida",
  "Trato cercano",
  "Resultados naturales",
];
---

<section
  id="cta-whatsapp"
  class="px-4 py-14 sm:px-6 sm:py-18 md:py-22 lg:px-10 lg:py-28"
>
  <div class="mx-auto max-w-7xl">
    <div class="grid items-center gap-10 lg:grid-cols-[0.92fr_1.08fr] lg:gap-16">
      <!-- Texto -->
      <div class="order-2 lg:order-1">
        <span class="inline-flex items-center gap-2 rounded-full border border-[#e8dfda] px-4 py-2 text-[10px] font-semibold uppercase tracking-[0.22em] text-[#8a7670] sm:text-[11px]">
          <span class="h-1.5 w-1.5 rounded-full bg-[#25d366]"></span>
          Contacto inmediato
        </span>

        <h2 class="mt-5 max-w-[12ch] text-[2.2rem] font-light leading-[0.95] tracking-[-0.05em] text-[#171414] sm:text-[2.8rem] md:text-[3.8rem] lg:max-w-[10ch] lg:text-[5rem]">
          Tu sonrisa
          <span class="block font-medium text-[#2b201e]">
            empieza con un mensaje
          </span>
        </h2>

        <p class="mt-6 max-w-xl text-[0.98rem] leading-relaxed text-[#5a4c48] sm:text-[1.04rem] md:text-[1.1rem] lg:text-[1.18rem]">
          Escríbenos por WhatsApp y te ayudamos a entender qué sigue, qué opción
          puede ir mejor contigo y cómo sería tu proceso de forma simple y cercana.
        </p>

        <div class="mt-7 flex flex-wrap gap-2.5 sm:gap-3">
          {puntos.map((item) => (
            <span class="inline-flex rounded-full border border-[#ece4e0] px-3.5 py-2 text-xs font-medium text-[#2a2220] transition duration-300 hover:-translate-y-0.5 hover:border-[#d9ccc6] hover:shadow-[0_10px_22px_rgba(0,0,0,0.05)] sm:px-4 sm:text-sm">
              {item}
            </span>
          ))}
        </div>

        <div class="mt-8 max-w-lg border-l border-[#e9dfda] pl-4 sm:pl-5">
          <p class="text-[0.94rem] leading-relaxed text-[#786964] sm:text-[0.98rem] md:text-[1rem]">
            Sin vueltas raras, sin presión y sin hacerte sentir como un paciente más.
            Solo una conversación clara para ayudarte a dar el primer paso.
          </p>
        </div>
      </div>

      <!-- Imagen -->
      <div class="order-1 lg:order-2">
        <div class="scene relative mx-auto w-full max-w-85 sm:max-w-117.5 md:max-w-155 lg:max-w-190">
          <!-- halo -->
          <div class="pointer-events-none absolute inset-x-[10%] top-[10%] -z-20 h-[76%] rounded-full bg-[radial-gradient(circle,rgba(77,180,191,0.14)_0%,rgba(77,180,191,0.05)_46%,transparent_76%)] blur-[54px]"></div>

          <!-- sombra -->
          <div class="pointer-events-none absolute inset-x-[15%] bottom-8 -z-10 hidden h-12 rounded-full bg-black/10 blur-2xl lg:block"></div>

          <!-- note -->
          <div class="floating-note absolute left-0 top-8 z-20 hidden rounded-[1.25rem] border border-[#ece5e1] bg-white/96 px-4 py-3 shadow-[0_16px_34px_rgba(0,0,0,0.08)] xl:block">
            <p class="text-[10px] font-semibold uppercase tracking-[0.22em] text-[#9b847c]">
              Primer contacto
            </p>
            <p class="mt-1 text-sm font-medium text-[#241b19]">
              Te orientamos según tu caso
            </p>
          </div>

          <!-- imagen -->
           <img
  src={equipoImg.src}
  alt="Equipo médico de Maxilodental Studio"
  width={equipoImg.attributes.width}
  height={equipoImg.attributes.height}
  loading="lazy"
  decoding="async"
  class="team-image ..."
/>
          
          <!-- WhatsApp dock -->
          <a
            href={WHATSAPP_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="wa-dock relative z-30 mt-4 flex w-full items-center gap-3 rounded-[1.4rem] border border-[#efe8e4] bg-white px-3.5 py-3.5 shadow-[0_18px_38px_rgba(0,0,0,0.12)] transition duration-300 hover:-translate-y-1 hover:shadow-[0_24px_52px_rgba(0,0,0,0.16)] sm:gap-4 sm:rounded-[1.9rem] sm:px-4 sm:py-4 md:px-5 md:py-5 lg:absolute lg:bottom-[4%] lg:left-8 lg:mt-0 lg:max-w-115"
          >
            <span class="inline-flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-[#25d366] text-white shadow-[0_14px_30px_rgba(37,211,102,0.28)] sm:h-14 sm:w-14 md:h-16 md:w-16">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 32 32"
                fill="currentColor"
                class="h-6 w-6 sm:h-7 sm:w-7 md:h-8 md:w-8"
                aria-hidden="true"
              >
                <path
                  d="M19.11 17.34c-.27-.13-1.6-.79-1.85-.88-.25-.09-.43-.13-.62.13-.18.27-.71.88-.87 1.06-.16.18-.32.2-.59.07-.27-.13-1.15-.42-2.19-1.33-.81-.72-1.36-1.6-1.52-1.87-.16-.27-.02-.41.12-.54.12-.12.27-.32.4-.48.13-.16.18-.27.27-.45.09-.18.04-.34-.02-.48-.07-.13-.62-1.5-.85-2.06-.22-.53-.44-.46-.62-.47h-.53c-.18 0-.48.07-.73.34s-.96.94-.96 2.28.99 2.63 1.13 2.81c.13.18 1.94 2.96 4.7 4.15.66.29 1.18.46 1.58.59.66.21 1.26.18 1.73.11.53-.08 1.6-.65 1.83-1.28.22-.63.22-1.17.16-1.28-.07-.11-.25-.18-.52-.32Z"
                />
                <path
                  d="M16.02 3.2c-7.05 0-12.76 5.71-12.76 12.76 0 2.24.58 4.42 1.69 6.34L3.2 28.8l6.7-1.71a12.73 12.73 0 0 0 6.11 1.56h.01c7.04 0 12.78-5.71 12.78-12.76 0-3.41-1.33-6.61-3.75-9.02A12.67 12.67 0 0 0 16.02 3.2Zm0 23.29h-.01a10.5 10.5 0 0 1-5.35-1.47l-.38-.22-3.98 1.02 1.06-3.88-.25-.4a10.53 10.53 0 1 1 8.91 4.95Z"
                />
              </svg>
            </span>

            <span class="min-w-0 flex-1">
              <span class="block text-[9px] font-semibold uppercase tracking-[0.22em] text-[#8f7e78] sm:text-[10px] md:text-[11px]">
                WhatsApp directo
              </span>
              <span class="mt-1 block text-[0.98rem] font-semibold leading-tight text-[#1f1715] sm:text-[1.05rem] md:text-[1.22rem]">
                Agenda tu valoración
              </span>
              <span class="mt-1 block text-[0.82rem] leading-relaxed text-[#726661] sm:text-sm">
                Respuesta rápida y orientación clara.
              </span>
            </span>

            <span class="wa-open inline-flex shrink-0 items-center rounded-full bg-[#171414] px-3.5 py-2 text-xs font-medium text-white transition duration-300 sm:px-4 sm:py-2.5 sm:text-sm md:px-5">
              Abrir
            </span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .scene {
    animation: sceneEnter 0.9s ease both;
  }

  .team-image {
    animation: floatSoft 8s ease-in-out infinite;
  }

  .floating-note {
    animation: noteIn 1s ease both;
  }

  .wa-dock {
    animation: dockFade 0.9s ease both;
  }

  .wa-dock:hover .wa-open {
    background: #25d366;
  }

  @keyframes sceneEnter {
    from {
      opacity: 0;
      transform: translateY(18px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes dockFade {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes noteIn {
    from {
      opacity: 0;
      transform: translateY(12px) rotate(-3deg);
    }
    to {
      opacity: 1;
      transform: translateY(0) rotate(-3deg);
    }
  }

  @keyframes floatSoft {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-7px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .scene,
    .team-image,
    .floating-note,
    .wa-dock,
    .wa-open {
      animation: none !important;
      transition: none !important;
      transform: none !important;
    }
  }
</style>