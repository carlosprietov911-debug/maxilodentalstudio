---
const pilares = [
  {
    numero: "01",
    titulo: "Diagnóstico y plan personalizado",
    descripcion:
      "Estudiamos tu caso con detalle para definir un tratamiento claro, realista y adaptado a tus necesidades.",
  },
  {
    numero: "02",
    titulo: "Resultados armónicos y naturales",
    descripcion:
      "Integramos criterio clínico y herramientas digitales para lograr precisión, estética y equilibrio.",
  },
  {
    numero: "03",
    titulo: "Calidad clínica y protocolos",
    descripcion:
      "Trabajamos con procesos organizados, materiales confiables y altos estándares de bioseguridad.",
  },
];

const indicadores = [
  "Atención cercana",
  "Tecnología digital",
  "Bioseguridad",
  "Acompañamiento real",
];
---

<section
  id="pacientes-confianza"
  class="relative overflow-hidden bg-[#f8f2f0] px-4 py-12 sm:px-6 md:py-16 lg:px-10 lg:py-24"
>
  <!-- fondo -->
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute inset-0 bg-[#f8f2f0]"></div>
    <div class="absolute left-[-20%] top-[-8%] h-56 w-56 rounded-full bg-[#4DB4BF]/12 blur-3xl md:left-[-8%] md:top-[-10%] md:h-72 md:w-72"></div>
    <div class="absolute bottom-[-10%] right-[-12%] h-64 w-64 rounded-full bg-[#efd8d1]/40 blur-3xl md:bottom-[-12%] md:right-[-6%] md:h-80 md:w-80"></div>
    <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(255,255,255,0.42)_0%,rgba(255,255,255,0.08)_38%,rgba(255,255,255,0.28)_100%)]"></div>
  </div>

  <div class="mx-auto max-w-7xl">
    <!-- breadcrumb -->
    <div class="flex flex-wrap items-center gap-2 text-[0.72rem] font-medium uppercase tracking-[0.14em] text-[#7d6c66] sm:gap-3 sm:text-[0.78rem] sm:tracking-[0.16em]">
      <a href="/" class="transition hover:text-[#111111]">Inicio</a>
      <span class="text-[#b79f97]">/</span>
      <span class="text-[#111111]">Pacientes</span>
    </div>

    <div class="mt-8 grid items-center gap-10 lg:grid-cols-[1.02fr_.98fr] lg:gap-16">
      <!-- texto -->
      <div class="min-w-0">
        <span class="inline-flex items-center gap-2 rounded-full border border-[#eaded9] bg-white/70 px-4 py-2 text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-[#8a756e] backdrop-blur-sm sm:text-[0.72rem] sm:tracking-[0.2em]">
          Confianza en cada paso
        </span>

        <h2
          class="mt-5 max-w-3xl text-[2.15rem] font-light leading-[1.02] tracking-[-0.03em] text-[#171312] sm:text-[2.8rem] md:text-5xl lg:text-[4.1rem]"
        >
          Tu sonrisa, en buenas manos
        </h2>

        <p
          class="mt-5 max-w-2xl text-[0.98rem] leading-relaxed text-[#544946] sm:text-[1.02rem] md:text-[1.12rem] lg:text-[1.15rem]"
        >
          Combinamos experiencia clínica, tecnología digital y un trato cercano
          para que vivas tu tratamiento con tranquilidad, claridad y seguridad
          desde el primer día.
        </p>

        <!-- etiquetas -->
        <div class="mt-7 flex flex-wrap gap-2.5 sm:gap-3">
          {indicadores.map((item) => (
            <span
              class="rounded-full border border-white/80 bg-white/80 px-3.5 py-2 text-[0.86rem] text-[#3d3431] shadow-[0_8px_24px_rgba(17,17,17,0.04)] ring-1 ring-black/5 backdrop-blur-sm transition duration-300 hover:-translate-y-0.5 sm:px-4 sm:text-sm"
            >
              {item}
            </span>
          ))}
        </div>

        <!-- cards -->
        <div class="mt-8 space-y-4 sm:mt-10">
          {pilares.map((item) => (
            <article
              class="group rounded-[1.35rem] border border-white/70 bg-white/78 p-4 shadow-[0_14px_35px_rgba(17,17,17,0.06)] ring-1 ring-black/4 backdrop-blur-sm transition duration-300 hover:-translate-y-1 hover:shadow-[0_22px_45px_rgba(17,17,17,0.08)] sm:rounded-[1.55rem] sm:p-5 md:p-6"
            >
              <div class="flex items-start gap-3.5 sm:gap-4 md:gap-5">
                <div
                  class="flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-[#dff4f6] text-sm font-semibold text-[#26454b] sm:h-12 sm:w-12 md:h-14 md:w-14 md:text-base"
                >
                  {item.numero}
                </div>

                <div class="min-w-0">
                  <h3 class="text-base font-semibold leading-snug text-[#201a18] sm:text-lg md:text-[1.1rem]">
                    {item.titulo}
                  </h3>
                  <p class="mt-2 text-[0.94rem] leading-relaxed text-[#5f5350] sm:text-[0.98rem] md:text-[1.02rem]">
                    {item.descripcion}
                  </p>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>

      <!-- bloque visual abstracto -->
      <div class="relative mx-auto w-full max-w-136 lg:max-w-xl">
        <div
          class="relative isolate overflow-hidden rounded-[1.8rem] border border-white/70 bg-white/55 p-4 shadow-[0_24px_70px_rgba(17,17,17,0.08)] ring-1 ring-black/5 backdrop-blur-md sm:p-5 md:rounded-4xl md:p-8"
        >
          <!-- capas decorativas -->
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(77,180,191,0.18),transparent_34%),radial-gradient(circle_at_bottom_right,rgba(240,214,206,0.50),transparent_34%)]"></div>

          <div class="relative flex min-h-80 items-center justify-center sm:min-h-95 md:min-h-117.5">
            <!-- círculos -->
            <div class="absolute h-60 w-60 rounded-full border border-[#4DB4BF]/20 sm:h-72 sm:w-[18rem] md:h-80 md:w-80"></div>
            <div class="absolute h-46 w-46 rounded-full border border-[#e6c8c0]/40 sm:h-56 sm:w-56 md:h-64 md:w-64"></div>
            <div class="absolute h-36 w-36 rounded-full border border-[#4DB4BF]/25 motion-safe:animate-[spin_18s_linear_infinite] sm:h-44 sm:w-44 md:h-52 md:w-52"></div>
            <div class="absolute h-[6.8rem] w-[6.8rem] rounded-full bg-white/75 shadow-[0_10px_30px_rgba(17,17,17,0.05)] backdrop-blur-sm sm:h-32 sm:w-32 md:h-36 md:w-36"></div>

            <!-- núcleo -->
            <div class="relative z-10 max-w-56 text-center sm:max-w-60 md:max-w-[16rem]">
              <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-[1.4rem] bg-[#dff4f6] shadow-[0_14px_35px_rgba(77,180,191,0.20)] sm:h-18 sm:w-18 md:h-20 md:w-20 md:rounded-[1.7rem]">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.65"
                  class="h-7 w-7 text-[#24444a] sm:h-8 sm:w-8 md:h-9 md:w-9"
                >
                  <path d="M12 21s-6.5-4.35-8.5-8.2C1.7 9.2 3.8 5 8.3 5c1.8 0 3 .9 3.7 2 .7-1.1 1.9-2 3.7-2 4.5 0 6.6 4.2 4.8 7.8C18.5 16.65 12 21 12 21Z" />
                </svg>
              </div>

              <h3 class="mt-4 text-[1.45rem] font-light tracking-tight text-[#1a1413] sm:text-[1.65rem] md:mt-5 md:text-[1.9rem]">
                Cuidamos tu proceso
              </h3>
              <p class="mt-3 text-[0.92rem] leading-relaxed text-[#5c514e] sm:text-[0.96rem] md:text-[0.98rem]">
                No solo buscamos un buen resultado, también queremos que te
                sientas acompañado, informado y tranquilo en cada etapa.
              </p>
            </div>

            <!-- badges flotantes -->
            <div
              class="absolute left-2 top-4 max-w-[8.8rem] rounded-2xl border border-white/80 bg-white/90 px-3 py-2.5 shadow-[0_12px_28px_rgba(17,17,17,0.07)] backdrop-blur-sm motion-safe:animate-[pulse_4s_ease-in-out_infinite] sm:left-4 sm:top-6 sm:max-w-40x-4 sm:py-3 md:top-8"
            >
              <p class="text-[0.62rem] font-semibold uppercase tracking-[0.16em] text-[#8d7770] sm:text-[0.68rem] sm:tracking-[0.18em]">
                Precisión
              </p>
              <p class="mt-1 text-[0.82rem] leading-snug text-[#3e3532] sm:text-sm">
                Diagnóstico claro
              </p>
            </div>

            <div
              class="absolute right-2 top-8 hidden max-w-36 rounded-2xl border border-white/80 bg-white/90 px-3 py-2.5 shadow-[0_12px_28px_rgba(17,17,17,0.07)] backdrop-blur-sm motion-safe:animate-[pulse_5s_ease-in-out_infinite] sm:block sm:right-4 sm:top-10 sm:max-w-40 sm:px-4 sm:py-3 md:top-18"
            >
              <p class="text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-[#8d7770]">
                Confianza
              </p>
              <p class="mt-1 text-sm text-[#3e3532]">Acompañamiento real</p>
            </div>

            <div
              class="absolute bottom-6 left-3 max-w-36 rounded-2xl border border-white/80 bg-white/90 px-3 py-2.5 shadow-[0_12px_28px_rgba(17,17,17,0.07)] backdrop-blur-sm motion-safe:animate-[pulse_4.8s_ease-in-out_infinite] sm:bottom-8 sm:left-6 sm:max-w-40 sm:px-4 sm:py-3 md:bottom-10"
            >
              <p class="text-[0.62rem] font-semibold uppercase tracking-[0.16em] text-[#8d7770] sm:text-[0.68rem] sm:tracking-[0.18em]">
                Cuidado
              </p>
              <p class="mt-1 text-[0.82rem] leading-snug text-[#3e3532] sm:text-sm">
                Protocolos seguros
              </p>
            </div>

            <div
              class="absolute bottom-5 right-3 hidden max-w-36 rounded-2xl border border-white/80 bg-white/90 px-3 py-2.5 shadow-[0_12px_28px_rgba(17,17,17,0.07)] backdrop-blur-sm motion-safe:animate-[pulse_5.4s_ease-in-out_infinite] sm:block sm:bottom-6 sm:right-6 sm:max-w-40 sm:px-4 sm:py-3"
            >
              <p class="text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-[#8d7770]">
                Estética
              </p>
              <p class="mt-1 text-sm text-[#3e3532]">Resultados naturales</p>
            </div>
          </div>

          <!-- indicadores inferiores -->
          <div class="relative z-10 mt-3 grid gap-3 sm:mt-4 sm:grid-cols-3">
            <div class="rounded-2xl border border-white/75 bg-white/80 px-4 py-4 text-center backdrop-blur-sm">
              <p class="text-[0.68rem] uppercase tracking-[0.14em] text-[#8e7871] sm:text-[0.7rem] sm:tracking-[0.16em]">
                Enfoque
              </p>
              <p class="mt-1 text-sm font-medium text-[#231d1b] md:text-base">
                Personalizado
              </p>
            </div>

            <div class="rounded-2xl border border-white/75 bg-white/80 px-4 py-4 text-center backdrop-blur-sm">
              <p class="text-[0.68rem] uppercase tracking-[0.14em] text-[#8e7871] sm:text-[0.7rem] sm:tracking-[0.16em]">
                Atención
              </p>
              <p class="mt-1 text-sm font-medium text-[#231d1b] md:text-base">
                Cercana
              </p>
            </div>

            <div class="rounded-2xl border border-white/75 bg-white/80 px-4 py-4 text-center backdrop-blur-sm">
              <p class="text-[0.68rem] uppercase tracking-[0.14em] text-[#8e7871] sm:text-[0.7rem] sm:tracking-[0.16em]">
                Objetivo
              </p>
              <p class="mt-1 text-sm font-medium text-[#231d1b] md:text-base">
                Bienestar
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>