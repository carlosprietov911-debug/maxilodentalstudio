---
interface CasoACF {
  imagen_antes: number | null;
  imagen_despues: number | null;
  descripcion: string;
}

interface CasoRaw {
  slug: string;
  title: { rendered: string };
  acf?: CasoACF;
}

interface Caso {
  slug: string;
  title: { rendered: string };
  descripcion: string;
  imagenAntes: string | null;
  imagenDespues: string | null;
}

const credentials = btoa(`${import.meta.env.WP_USER}:${import.meta.env.WP_PASSWORD}`);
const headers = {
  Authorization: `Basic ${credentials}`,
};

// 🔹 Mejor manejo de media
const getImageUrl = async (id: number | null): Promise<string | null> => {
  if (!id) return null;

  try {
    const res = await fetch(
      `https://cms.maxilodentalstudio.com/wp-json/wp/v2/media/${id}`,
      { headers }
    );

    if (!res.ok) return null;

    const data: any = await res.json();
    return data?.source_url ?? null;
  } catch {
    return null;
  }
};

// 🔹 Fetch principal con validación
const res = await fetch(
  "https://cms.maxilodentalstudio.com/wp-json/wp/v2/casos",
  { headers }
);

if (!res.ok) {
  throw new Error("Error cargando casos");
}

const casosRaw: CasoRaw[] = await res.json();

// 🔹 Transformación
const casos: Caso[] = await Promise.all(
  casosRaw.map(async (caso) => ({
    slug: caso.slug,
    title: caso.title,
    descripcion: caso.acf?.descripcion ?? "",
    imagenAntes: await getImageUrl(caso.acf?.imagen_antes ?? null),
    imagenDespues: await getImageUrl(caso.acf?.imagen_despues ?? null),
  }))
);
---

<section id="casos" class="mt-6 md:mt-10">
  <div class="mx-auto max-w-7xl px-6 pb-24 md:pb-28 lg:px-10 lg:pb-32">
    <ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 list-none p-0 m-0">
      {casos.map((caso) => (
        <li class="flex">
          <a
            href={`/casosclinicos/${caso.slug}`}
            class="group flex w-full flex-col overflow-hidden rounded-[1.6rem] border border-white/70 bg-white/80 shadow-[0_14px_35px_rgba(0,0,0,0.06)] backdrop-blur-sm transition duration-300 hover:-translate-y-1 hover:shadow-[0_18px_45px_rgba(0,0,0,0.08)]"
          >
            <div class="relative overflow-hidden shrink-0">
              {caso.imagenAntes && (
                <img
                  src={caso.imagenAntes}
                  alt={caso.title.rendered}
                  class="h-56 w-full object-cover transition duration-500 group-hover:scale-[1.04]"
                />
              )}

              <div class="absolute inset-0 bg-linear-to-t from-black/25 via-black/0 to-transparent opacity-70"></div>

              <span class="absolute top-3 left-3 rounded-full bg-white/90 px-3 py-1 text-[11px] font-semibold text-[#2AA7B0] backdrop-blur">
                Caso clínico
              </span>
            </div>

            <div class="flex flex-1 flex-col p-5">
              <h3 class="text-[1.05rem] font-semibold text-[#2b2020]">
                {caso.title.rendered}
              </h3>

              {caso.descripcion && (
                <p class="mt-2 flex-1 text-sm leading-relaxed text-[#5c5f66]">
                  {caso.descripcion}
                </p>
              )}

              <div class="mt-4 flex items-center gap-1.5 text-sm font-medium text-[#2AA7B0]">
                Ver caso
                <span class="transition duration-300 group-hover:translate-x-1">→</span>
              </div>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>