---
import AstrIcon from "../../../assets/dental.svg";
import AstrIcon1 from "../../../assets/dental1.svg";
import WhatsappI from "../../../assets/wicon.svg";
import portada from "../../../assets/imagen_Hero.png";
import cirugiaImg from "../../../assets/excelencia-clinica.png";
import { Picture, Image } from "astro:assets";
---

<!-- HERO -->
<section class="px-6 py-6 md:py-14 lg:px-10 lg:py-1">
  <div class="mx-auto max-w-7xl">
    <div class="grid grid-cols-1 items-star gap-10 lg:grid-cols-2 lg:gap-14">
      <!-- Texto -->
      <div class="order-1 space-y-6">
        <h1
          class="text-xl font-medium leading-snug md:text-2xl motion-safe:animate-[fadeUp_.7s_ease-out_both]"
        >
          Cirugía maxilofacial & odontología estética
        </h1>

        <p
          class="max-w-2xl text-base font-normal leading-relaxed text-[#000000] md:text-xl motion-safe:animate-[fadeUp_.7s_ease-out_both] [animation-delay:120ms]"
        >
          Líderes en odontología estética, maxilofacial y cirugía oral. 12 años
          de trayectoria en Fusagasugá.
        </p>

        <h2
          class="max-w-3xl text-3xl font-bold leading-tight tracking-tighter text-[#2e2323] md:text-4xl lg:text-3xl motion-safe:animate-[fadeUp_.7s_ease-out_both] [animation-delay:220ms]"
        >
          Excelencia, tecnología y calidez: un nuevo estándar de atención
          especializada en Fusagasugá
        </h2>

        <div
          class="flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center sm:gap-4"
        >
          <a
            href="https://wa.link/u29whe"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex w-full items-center justify-center gap-3 rounded-full bg-[#25D366] px-8 py-3 text-base font-semibold text-white shadow-md transition hover:scale-[1.02] hover:shadow-lg sm:w-auto"
          >
            <WhatsappI width={32} height={32} />
            Agenda tu cita
          </a>

          <a
            href="/servicios"
            class="inline-flex w-full items-center justify-center rounded-full border border-[#d7caca] bg-white px-6 py-3 text-base font-semibold text-[#0c0c0c] transition hover:bg-[#f8f5f5] sm:w-auto"
          >
            Ver servicios
          </a>
        </div>

        <!-- Cards -->
        <div class="grid gap-6 pt-4 md:grid-cols-2">
          <article
            class="rounded-2xl bg-white p-4 ring-1 ring-black/5 shadow-xl shadow-black/10 md:p-5 transition duration-300 hover:-translate-y-1 hover:shadow-2xl hover:ring-black/10"
          >
            <AstrIcon width="72" height="72" />
            <h3
              class="mb-2 mt-3 text-xl font-bold leading-snug text-[#000000] md:text-2xl transition group-hover:translate-x-0.5"
            >
              Tratamientos hechos a tu medida
            </h3>
            <p class="text-base leading-relaxed text-[#000000]">
              Cada sonrisa se diseña respetando tus rasgos, tu estilo y tus
              objetivos. Nada es genérico: analizamos tu caso.
            </p>
          </article>

          <article
            class="rounded-2xl bg-white p-4 ring-1 ring-black/5 shadow-xl shadow-black/10 md:p-5 transition duration-300 hover:-translate-y-1 hover:shadow-2xl hover:ring-black/10"
          >
            <AstrIcon1 width={72} height={72} />
            <h3
              class="mb-2 mt-3 text-xl font-bold leading-snug text-[#000000] md:text-2xl"
            >
              Acompañamiento real de inicio a fin
            </h3>
            <p class="text-base leading-relaxed text-[#000000]">
              Te escuchamos, resolvemos tus dudas y te guiamos en cada etapa del
              proceso. Tu seguridad es nuestra prioridad.
            </p>
          </article>
          
        </div>
      </div>
      <!-- Imagen -->
<div
  class="group order-2 relative flex justify-center lg:justify-end motion-safe:animate-[heroImageIn_.9s_cubic-bezier(.22,1,.36,1)_both]"
>
  <div
    class="relative w-full max-w-75 pb-16 sm:max-w-95 md:max-w-110 lg:max-w-130"
  >
    <!-- Imagen principal -->
    <div class="will-change-transform motion-safe:animate-[heroFloat_6s_ease-in-out_infinite]">
      <Picture
        class="h-auto w-full object-contain transition duration-500 ease-out will-change-transform
               filter-[drop-shadow(0_12px_18px_rgba(0,0,0,0.18))_drop-shadow(0_28px_45px_rgba(0,0,0,0.14))]
               group-hover:scale-[1.02] group-hover:-translate-y-1"
        src={portada}
        alt="imagen principal doctor"
        formats={["avif", "webp"]}
      />
    </div>

    <!-- halo suave detrás -->
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-x-[12%] top-[8%] -z-10 h-[72%] rounded-full bg-[#4DB4BF]/12 blur-3xl
             motion-safe:animate-[heroGlow_5.5s_ease-in-out_infinite]"
    ></div>

    <!-- Badge / Recuadro con textura -->
    <div
      class="absolute left-1/2 -bottom-6 w-[96%] -translate-x-1/2
             sm:w-[86%] md:w-[84%] lg:w-[78%]
             motion-safe:animate-[badgeIn_1s_cubic-bezier(.22,1,.36,1)_both]
             [animation-delay:220ms]"
    >
      <div
        class="relative overflow-hidden rounded-3xl
               bg-linear-to-br from-[#4DB4BF] via-[#3aa9b4] to-[#2e8f99]
               px-8 py-8 text-center text-xl font-extrabold text-white
               shadow-[0_26px_70px_-35px_rgba(0,0,0,0.65)]
               ring-1 ring-black/10 transition duration-500 ease-out
               md:px-12 md:py-10 md:text-2xl
               group-hover:-translate-y-1 group-hover:shadow-[0_34px_90px_-35px_rgba(0,0,0,0.72)]"
      >
        <!-- grain -->
        <div
          aria-hidden="true"
          class="pointer-events-none absolute inset-0 opacity-[0.18]
                 bg-[radial-gradient(rgba(255,255,255,.65)_1px,transparent_1px)]
                 bg-size:[10px_10px]"
        ></div>

        <!-- glow interno sutil -->
        <div
          aria-hidden="true"
          class="pointer-events-none absolute inset-0 opacity-40
                 bg-[radial-gradient(circle_at_50%_20%,rgba(255,255,255,0.22),transparent_55%)]
                 motion-safe:animate-[badgeGlow_4.5s_ease-in-out_infinite]"
        ></div>

        <!-- shine -->
        <div
          aria-hidden="true"
          class="pointer-events-none absolute inset-y-0 left-0 w-1/2
                 bg-[linear-gradient(90deg,transparent,rgba(255,255,255,.55),transparent)]
                 motion-safe:animate-[shine_3.2s_ease-in-out_infinite]"
        ></div>

        <p class="relative m-0 leading-tight">
          12 años de trayectoria en Fusagasugá
        </p>

        <p
          class="relative mt-2 text-sm font-semibold text-white/90 md:text-base"
        >
          Agenda tu valoración por WhatsApp
        </p>
      </div>
    </div>
  </div>
</div>

      
    </div>
  </div>

  <!-- SEGUNDA SECCIÓN (Imagen izquierda / Texto derecha) - Diseño nuevo -->
  <section
    class="relative mt-16 overflow-hidden px-6 py-20 md:py-24 lg:mt-24 lg:px-10"
  >
    <!-- Fondo diferente (patrón + brillos suaves) -->
    <div class="pointer-events-none absolute inset-0 -z-10">
      <div
        class="absolute -top-28 -left-4020px] w-105 rounded-full bg-[#4DB4BF]/18 blur-3xl"
      >
      </div>
      <div class=""></div>
    </div>

    <div class="mx-auto max-w-7xl">
      <div
        class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2 lg:gap-16"
      >
        <!-- IMAGEN (izquierda) -->
        <div
          class="order-1 flex justify-center lg:justify-start motion-safe:animate-[fadeUp_.7s_ease-out_both]"
        >
          <div
            class="group relative w-full max-w-82.5 sm:max-w-90 md:max-w-100"
          >
            <!-- marco/halo -->
            <div
              class="absolute -inset-4 -z-10 rounded-[2.75rem] bg-white/40 blur-xl"
            >
            </div>
            <div
              class="absolute -inset-7 -z-10 rounded-[3rem] bg-[#4DB4BF]/10 blur-2xl transition duration-300 group-hover:bg-[#4DB4BF]/14"
            >
            </div>

            <div
              class="relative overflow-hidden rounded-[2.25rem] ring-1 ring-black/10 bg-white shadow-[0_26px_70px_-38px_rgba(0,0,0,0.60)]"
            >
              <!-- overlay suave para profundidad -->
              <div
                aria-hidden="true"
                class="pointer-events-none absolute inset-0 bg-[linear-gradient(145deg,rgba(255,255,255,0.20),transparent_55%)]"
              >
              </div>

              <!-- shine (distinto al anterior: más corto) -->
              <div
                aria-hidden="true"
                class="pointer-events-none absolute -left-1/2 top-0 h-full w-1/2
                     bg-[linear-gradient(90deg,transparent,rgba(255,255,255,0.50),transparent)]
                     -skew-x-12 opacity-0 transition duration-500
                     group-hover:translate-x-[210%] group-hover:opacity-100"
              >
              </div>

              <Image
                src={cirugiaImg}
                alt="Procedimiento clínico"
                width={420}
                height={560}
                sizes="(min-width: 1024px) 420px, (min-width: 768px) 400px, 88vw"
                class="relative h-auto w-full object-cover transition duration-500 group-hover:scale-[1.03]"
              />
            </div>
          </div>
        </div>

        <!-- TEXTO (derecha) -->
        <div
          class="order-2 max-w-170 motion-safe:animate-[fadeUp_.7s_ease-out_both] [animation-delay:120ms]"
        >
          <!-- título con acento lateral (detalle diferente) -->
          <div class="mt-5 flex gap-4">
            <span
              class="mt-2 hidden h-12 w-1 rounded-full bg-[#4DB4BF]/70 lg:block"
            ></span>
            <div>
              <h2
                class="text-3xl font-extrabold leading-tight tracking-tight text-[#2e2323] md:text-4xl lg:text-5xl"
              >
                Excelencia Clínica
              </h2>
              <p
                class="mt-2 text-sm font-semibold text-[#4b3f3f]/75 md:text-base"
              >
                Enfoque digital para resultados predecibles.
              </p>
            </div>
          </div>

          <div
            class="mt-6 space-y-5 text-base leading-relaxed text-[#4b3f3f] md:text-lg lg:text-xl"
          >
            <p>
              En Maxilodental Studio trabajamos con altos estándares clínicos,
              tecnología avanzada y un enfoque humano para brindarte resultados
              reales, estéticos y duraderos.
            </p>
            <p>
              También incorporamos tecnología digital 3D, que nos permite
              planificar cada caso con precisión y asegurar resultados
              totalmente predecibles.
            </p>
          </div>

          <!-- chips/beneficios (detalles nuevos) -->
          <div class="mt-8 grid gap-3 sm:grid-cols-2">
            <div
              class="rounded-2xl bg-white/70 p-4 ring-1 ring-black/5 shadow-sm backdrop-blur transition hover:-translate-y-0.5 hover:shadow-md"
            >
              <p class="text-sm font-semibold text-[#2e2323]">
                Planificación 3D
              </p>
              <p class="mt-1 text-sm text-[#4b3f3f]">
                Mayor precisión y seguridad.
              </p>
            </div>
            <div
              class="rounded-2xl bg-white/70 p-4 ring-1 ring-black/5 shadow-sm backdrop-blur transition hover:-translate-y-0.5 hover:shadow-md"
            >
              <p class="text-sm font-semibold text-[#2e2323]">
                Seguimiento real
              </p>
              <p class="mt-1 text-sm text-[#4b3f3f]">
                Acompañamiento en cada etapa.
              </p>
            </div>
          </div>

          <div class="mt-12">
            <a
              href="/servicios"
              class="inline-flex w-full items-center justify-center gap-3 rounded-full bg-white px-12 py-6 text-base font-semibold text-[#0c0c0c]
                   ring-1 ring-black/10 shadow-md
                   transition duration-300
                   hover:-translate-y-0.5 hover:shadow-lg hover:ring-black/20
                   active:translate-y-0 sm:w-auto"
            >
              Ver servicios
              <span aria-hidden="true" class="text-lg">→</span>
            </a>
          </div>
        </div>
      </div>
    </div>

    <style>
      @keyframes fadeUp {
        from {
          opacity: 0;
          transform: translateY(14px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
    </style>
  </section>
</section>
 <section class="relative mt-16 overflow-hidden bg-[#f8fbfc] px-6 py-20 lg:px-10">
  <!-- transición desde la sección anterior -->
  <div class="absolute inset-x-0 top-0 h-20 bg-gradient-to-b from-[#d9d9d9]/50 to-transparent"></div>

  <!-- fondo decorativo sutil -->
  <div class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(900px_460px_at_15%_0%,rgba(77,180,191,0.10),transparent_60%),radial-gradient(800px_420px_at_90%_90%,rgba(243,217,212,0.18),transparent_60%)]"></div>

  <div class="mx-auto max-w-7xl">
    <div class="flex flex-col items-center text-center">
      <h2 class="text-3xl font-extrabold tracking-tight text-[#2e2323] md:text-4xl">
        Nuestra Promesa Contigo
      </h2>

      <div class="mt-10 grid w-full gap-5 sm:grid-cols-2 lg:grid-cols-4">
        <!-- Card 1 -->
        <article class="group relative rounded-3xl bg-white p-6 shadow-[0_8px_24px_rgba(0,0,0,0.06)] ring-1 ring-black/5 transition duration-300 hover:-translate-y-1 hover:shadow-[0_14px_34px_rgba(0,0,0,0.09)]">
          <div class="absolute right-6 top-6 text-sm font-extrabold text-[#2e2323]/20">01</div>
          <div class="mb-4 h-1 w-10 rounded-full bg-[#4DB4BF]/70 transition group-hover:w-14"></div>
          <h3 class="text-base font-bold text-[#2e2323]">Excelencia clínica</h3>
          <p class="mt-2 text-sm leading-relaxed text-[#4b3f3f]">
            Protocolos, tecnología y detalle.
          </p>
        </article>

        <!-- Card 2 -->
        <article class="group relative rounded-3xl bg-white p-6 shadow-[0_8px_24px_rgba(0,0,0,0.06)] ring-1 ring-black/5 transition duration-300 hover:-translate-y-1 hover:shadow-[0_14px_34px_rgba(0,0,0,0.09)]">
          <div class="absolute right-6 top-6 text-sm font-extrabold text-[#2e2323]/20">02</div>
          <div class="mb-4 h-1 w-10 rounded-full bg-[#4DB4BF]/70 transition group-hover:w-14"></div>
          <h3 class="text-base font-bold text-[#2e2323]">Diagnóstico personalizado</h3>
          <p class="mt-2 text-sm leading-relaxed text-[#4b3f3f]">
            Tu caso, tu plan, tu ritmo.
          </p>
        </article>

        <!-- Card 3 -->
        <article class="group relative rounded-3xl bg-white p-6 shadow-[0_8px_24px_rgba(0,0,0,0.06)] ring-1 ring-black/5 transition duration-300 hover:-translate-y-1 hover:shadow-[0_14px_34px_rgba(0,0,0,0.09)]">
          <div class="absolute right-6 top-6 text-sm font-extrabold text-[#2e2323]/20">03</div>
          <div class="mb-4 h-1 w-10 rounded-full bg-[#4DB4BF]/70 transition group-hover:w-14"></div>
          <h3 class="text-base font-bold text-[#2e2323]">Resultados naturales</h3>
          <p class="mt-2 text-sm leading-relaxed text-[#4b3f3f]">
            Estética sin exageración.
          </p>
        </article>

        <!-- Card 4 -->
        <article class="group relative rounded-3xl bg-white p-6 shadow-[0_8px_24px_rgba(0,0,0,0.06)] ring-1 ring-black/5 transition duration-300 hover:-translate-y-1 hover:shadow-[0_14px_34px_rgba(0,0,0,0.09)]">
          <div class="absolute right-6 top-6 text-sm font-extrabold text-[#2e2323]/20">04</div>
          <div class="mb-4 h-1 w-10 rounded-full bg-[#4DB4BF]/70 transition group-hover:w-14"></div>
          <h3 class="text-base font-bold text-[#2e2323]">Trato humano y cercano</h3>
          <p class="mt-2 text-sm leading-relaxed text-[#4b3f3f]">
            Acompañamiento real siempre.
          </p>
        </article>
      </div>
    </div>
  </div>
</section>