---
import { contactoData } from "../../../data/contacto";

import igClinicaPreviewImg from "../../../assets/ig_clinica_perfil.png?url";
import igYessicaImg from "../../../assets/ig_yessica.png?url";
import igCarlosImg from "../../../assets/ig_carlos.png?url";
---

<section
  id="redes"
  class="relative overflow-hidden px-4 py-10 sm:px-6 sm:py-14 md:py-18 lg:px-10 lg:py-24"
>
  <div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
    <div class="absolute left-[-10%] top-[6%] h-56 w-56 rounded-full bg-[#4DB4BF]/8 blur-3xl sm:h-72 sm:w-72"></div>
    <div class="absolute right-[-8%] top-[12%] h-64 w-64 rounded-full bg-[#ead7d0]/55 blur-3xl sm:h-80 sm:w-80"></div>
    <div class="absolute bottom-[-12%] left-[18%] h-56 w-56 rounded-full bg-white/40 blur-3xl sm:h-72 sm:w-72"></div>
  </div>

  <div class="mx-auto max-w-7xl">
    <!-- encabezado -->
    <div class="max-w-3xl">
      <p class="text-[10px] font-semibold uppercase tracking-[0.22em] text-[#a28780] sm:text-[11px] sm:tracking-[0.24em]">
        Redes sociales
      </p>

      <h2 class="mt-3 text-2xl font-light tracking-tight text-[#171717] sm:text-3xl md:text-4xl lg:text-[3.5rem]">
        Una presencia digital más
        <span class="italic text-[#8b736b]">cercana, sólida y coherente</span>
      </h2>

      <p class="mt-4 text-[15px] leading-relaxed text-[#5f5652] sm:text-base md:text-lg">
        En nuestras redes compartimos tratamientos, casos clínicos, resultados y
        momentos del día a día en consulta. Un espacio pensado para acercarte a
        MaxiloDental Studio con una imagen clara, profesional y alineada con
        nuestra forma de trabajar.
      </p>
    </div>

    <!-- bloque principal -->
    <div class="mt-8 grid gap-4 sm:mt-10 sm:gap-6 xl:grid-cols-[1.12fr_0.88fr]">
      <!-- instagram principal -->
      <a
        href={contactoData.instagramClinica}
        target="_blank"
        rel="noopener noreferrer"
        class="group relative overflow-hidden rounded-[28px] border border-[#171717] bg-[#171717] text-white shadow-[0_24px_70px_rgba(0,0,0,0.14)] transition duration-300 hover:-translate-y-1 sm:rounded-[34px] lg:rounded-[38px]"
      >
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(255,255,255,0.12),transparent_28%),radial-gradient(circle_at_bottom_right,rgba(255,255,255,0.06),transparent_26%),linear-gradient(180deg,rgba(255,255,255,0.02),rgba(255,255,255,0))]"></div>
        <div class="absolute inset-x-0 top-0 h-px bg-white/10"></div>
        <div class="absolute left-[-4%] top-[-10%] h-32 w-32 rounded-full bg-white/5 blur-3xl sm:h-44 sm:w-44"></div>
        <div class="absolute right-[-8%] bottom-[-10%] h-40 w-40 rounded-full bg-white/4 blur-3xl sm:h-56 sm:w-56"></div>

        <div class="relative p-5 sm:p-6 md:p-8 lg:p-9">
          <div class="flex flex-wrap items-center justify-between gap-3">
            <div class="flex flex-wrap items-center gap-2">
              <span class="rounded-full border border-white/12 bg-white/8 px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.16em] text-white/80 sm:text-[11px] sm:tracking-[0.18em]">
                Canal principal
              </span>
              <span class="rounded-full border border-white/12 px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.16em] text-white/58 sm:text-[11px] sm:tracking-[0.18em]">
                Instagram
              </span>
            </div>

            <span class="rounded-full border border-white/10 bg-white/6 px-3 py-1 text-[10px] uppercase tracking-[0.14em] text-white/58">
              @maxilodentalstudio
            </span>
          </div>

          <div class="mt-6 grid items-end gap-6 sm:mt-8 sm:gap-8 lg:grid-cols-[1.08fr_0.92fr]">
            <!-- izquierda -->
            <div>
              <div class="flex items-start gap-3 sm:gap-4 md:gap-5">
                <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-[18px] border border-white/10 bg-white/8 text-white shadow-[0_12px_30px_rgba(0,0,0,0.18)] sm:h-14 sm:w-14 sm:rounded-[20px]">
                  <svg
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                    class="h-6 w-6 fill-none stroke-current sm:h-7 sm:w-7"
                    stroke-width="1.8"
                  >
                    <rect x="3.5" y="3.5" width="17" height="17" rx="5.2"></rect>
                    <circle cx="12" cy="12" r="3.9"></circle>
                    <circle
                      cx="17.4"
                      cy="6.8"
                      r="0.9"
                      fill="currentColor"
                      stroke="none"
                    ></circle>
                  </svg>
                </div>

                <div class="max-w-xl">
                  <p class="text-[10px] font-semibold uppercase tracking-[0.2em] text-white/38 sm:text-[11px] sm:tracking-[0.24em]">
                    Presencia visual de la clínica
                  </p>

                  <h3 class="mt-3 text-2xl font-light leading-[1.04] tracking-tight text-white sm:text-3xl md:text-4xl lg:text-[2.9rem]">
                    Síguenos en Instagram
                  </h3>

                  <p class="mt-4 text-sm leading-relaxed text-white/72 md:text-base">
                    Descubre tratamientos, casos reales, avances clínicos y una
                    mirada más cercana al trabajo que realizamos en odontología
                    estética, implantes y cirugía maxilofacial.
                  </p>
                </div>
              </div>

              <div class="mt-6 rounded-[22px] border border-white/10 bg-white/4.5 p-4 backdrop-blur sm:mt-7 sm:rounded-[26px] sm:p-5">
                <p class="text-[10px] uppercase tracking-[0.16em] text-white/36">
                  Qué compartimos
                </p>

                <div class="mt-4 flex flex-wrap gap-2.5">
                  <span class="rounded-full border border-white/10 bg-white/6 px-3 py-2 text-[11px] font-medium text-white/78">
                    Diseño de sonrisa
                  </span>
                  <span class="rounded-full border border-white/10 bg-white/6 px-3 py-2 text-[11px] font-medium text-white/78">
                    Implantes dentales
                  </span>
                  <span class="rounded-full border border-white/10 bg-white/6 px-3 py-2 text-[11px] font-medium text-white/78">
                    Cirugía maxilofacial
                  </span>
                  <span class="rounded-full border border-white/10 bg-white/6 px-3 py-2 text-[11px] font-medium text-white/78">
                    Casos clínicos
                  </span>
                </div>
              </div>

              <div class="mt-6 flex flex-col gap-3 sm:mt-7 sm:flex-row sm:flex-wrap sm:items-center sm:gap-4">
                <span class="inline-flex w-full items-center justify-center gap-2 rounded-full bg-white px-5 py-3 text-sm font-semibold text-[#171717] transition duration-300 group-hover:opacity-90 sm:w-auto">
                  Ver Instagram
                  <svg
                    viewBox="0 0 20 20"
                    aria-hidden="true"
                    class="h-4 w-4"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                  >
                    <path d="M4.5 10h11"></path>
                    <path d="M10.5 4.5 16 10l-5.5 5.5"></path>
                  </svg>
                </span>

                <span class="text-center text-[11px] uppercase tracking-[0.16em] text-white/34 sm:text-left sm:text-xs">
                  Contenido actualizado
                </span>
              </div>
            </div>

            <!-- derecha -->
            <div class="grid gap-4">
              <div class="rounded-[22px] border border-white/10 bg-white/7 p-4 backdrop-blur sm:rounded-[28px] sm:p-5">
                <p class="text-[10px] uppercase tracking-[0.16em] text-white/38">
                  Nuestra presencia digital
                </p>
                <p class="mt-3 text-sm leading-relaxed text-white/74">
                  Un contenido pensado para transmitir confianza, detalle,
                  naturalidad y el nivel de cuidado que define cada tratamiento.
                </p>
              </div>

              <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-1">
                <div class="rounded-[20px] border border-white/10 bg-white/6 p-4 sm:rounded-3xl sm:p-5">
                  <p class="text-[10px] uppercase tracking-[0.16em] text-white/38">
                    Lo que encontrarás
                  </p>
                  <p class="mt-3 text-sm font-medium text-white">
                    Tratamientos, resultados y marca
                  </p>
                </div>

                <div class="rounded-[20px] border border-white/10 bg-white/6 p-4 sm:rounded-3xl sm:p-5">
                  <p class="text-[10px] uppercase tracking-[0.16em] text-white/38">
                    Experiencia
                  </p>
                  <p class="mt-3 text-sm font-medium text-white">
                    Una imagen más clara y consistente
                  </p>
                </div>
              </div>

              <div class="rounded-[20px] border border-white/10 bg-linear-to-r from-white/10 to-white/3 p-4 sm:rounded-3xl sm:p-5">
                <p class="text-[10px] uppercase tracking-[0.16em] text-white/38">
                  Identidad
                </p>
                <p class="mt-3 text-sm leading-relaxed text-white/74">
                  Cada publicación refleja la visión de una clínica enfocada en
                  estética, funcionalidad y atención personalizada.
                </p>
              </div>
            </div>
          </div>

          <div class="mt-6 grid gap-3 sm:mt-8 sm:grid-cols-3">
            <div class="rounded-[18px] border border-white/10 bg-white/6 px-4 py-4 sm:rounded-[22px]">
              <p class="text-[10px] uppercase tracking-[0.16em] text-white/40">
                Rol
              </p>
              <p class="mt-2 text-sm font-medium text-white">
                Red principal
              </p>
            </div>

            <div class="rounded-[18px] border border-white/10 bg-white/6 px-4 py-4 sm:rounded-[22px]">
              <p class="text-[10px] uppercase tracking-[0.16em] text-white/40">
                Contenido
              </p>
              <p class="mt-2 text-sm font-medium text-white">
                Clínica y tratamientos
              </p>
            </div>

            <div class="rounded-[18px] border border-white/10 bg-white/6 px-4 py-4 sm:rounded-[22px]">
              <p class="text-[10px] uppercase tracking-[0.16em] text-white/40">
                Imagen
              </p>
              <p class="mt-2 text-sm font-medium text-white">
                Cercana y profesional
              </p>
            </div>
          </div>
        </div>
      </a>

      <!-- columna secundaria -->
      <div class="grid gap-4 sm:gap-6">
        <!-- instagram preview -->
        <a
          href={contactoData.instagramClinica}
          target="_blank"
          rel="noopener noreferrer"
          class="group overflow-hidden rounded-[28px] border border-white/80 bg-white/86 shadow-[0_14px_35px_rgba(20,20,20,0.06)] backdrop-blur transition hover:-translate-y-1 sm:rounded-[34px]"
        >
          <div class="relative overflow-hidden rounded-t-[28px] bg-[#0f1115] sm:rounded-t-[34px]">
            <div class="absolute left-4 top-4 z-10 sm:left-5 sm:top-5">
              <span class="rounded-full border border-white/14 bg-black/18 px-3 py-2 text-[10px] font-semibold uppercase tracking-[0.2em] text-white/82 backdrop-blur sm:px-4 sm:text-[11px] sm:tracking-[0.22em]">
                Instagram
              </span>
            </div>

            <img
              src={igClinicaPreviewImg}
              alt="Vista previa del Instagram de MaxiloDental Studio"
              class="h-65 w-full object-cover object-top transition duration-500 group-hover:scale-[1.02] sm:h-80 md:h-85"
              loading="lazy"
            />

            <div class="absolute inset-x-0 bottom-0 bg-linear-to-t from-black/78 via-black/30 to-transparent px-4 pb-4 pt-10 sm:px-5 sm:pb-5 sm:pt-12">
              <p class="text-lg font-medium tracking-tight text-white sm:text-xl md:text-2xl">
                Preview visual
              </p>
              <p class="mt-2 max-w-sm text-sm leading-relaxed text-white/78">
                Una muestra del estilo del contenido
              </p>
            </div>
          </div>

          <div class="p-5 sm:p-6 md:p-7">
            <p class="text-[10px] font-semibold uppercase tracking-[0.2em] text-[#a28780] sm:text-[11px] sm:tracking-[0.22em]">
              Presentación visual
            </p>

            <h3 class="mt-3 text-xl font-medium tracking-tight text-[#171717] sm:text-2xl md:text-[2rem]">
              Instagram con mayor protagonismo
            </h3>

            <p class="mt-4 text-sm leading-relaxed text-[#5f5652] md:text-base">
              Un espacio donde compartimos tratamientos, resultados y contenido visual
              que refleja la identidad de MaxiloDental Studio con una imagen más
              cuidada, reconocible y coherente.
            </p>

            <div class="mt-5 flex flex-wrap gap-2">
              <span class="rounded-full border border-[#efe6e2] bg-[#fcfbfb] px-3 py-2 text-[11px] font-medium text-[#6d5d57]">
                Casos clínicos
              </span>
              <span class="rounded-full border border-[#efe6e2] bg-[#fcfbfb] px-3 py-2 text-[11px] font-medium text-[#6d5d57]">
                Estética dental
              </span>
              <span class="rounded-full border border-[#efe6e2] bg-[#fcfbfb] px-3 py-2 text-[11px] font-medium text-[#6d5d57]">
                Marca
              </span>
            </div>

            <span class="mt-6 inline-flex w-full items-center justify-center rounded-full border border-[#171717] px-4 py-2 text-sm font-semibold text-[#171717] transition group-hover:bg-[#171717] group-hover:text-white sm:w-auto">
              Ir a Instagram
            </span>
          </div>
        </a>

        <!-- facebook -->
        <a
          href={contactoData.facebook}
          target="_blank"
          rel="noopener noreferrer"
          class="group rounded-[28px] border border-[#ece3df] bg-white/84 p-5 shadow-[0_14px_35px_rgba(20,20,20,0.06)] backdrop-blur transition hover:-translate-y-1 sm:rounded-[34px] sm:p-6 md:p-7"
        >
          <div class="flex items-start justify-between gap-4">
            <div class="flex items-start gap-3 sm:gap-4">
              <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-[#1877F2]/10 text-[#1877F2] sm:h-12 sm:w-12 sm:rounded-2xl">
                <svg
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                  class="h-5 w-5 fill-current sm:h-6 sm:w-6"
                >
                  <path d="M22 12.07C22 6.5 17.52 2 12 2S2 6.5 2 12.07c0 5.03 3.66 9.2 8.44 9.93v-7.03H7.9v-2.9h2.54V9.85c0-2.52 1.49-3.91 3.78-3.91 1.1 0 2.24.2 2.24.2v2.47H15.2c-1.24 0-1.63.78-1.63 1.57v1.89h2.77l-.44 2.9h-2.33V22c4.78-.73 8.43-4.9 8.43-9.93Z"></path>
                </svg>
              </div>

              <div>
                <p class="text-[10px] font-semibold uppercase tracking-[0.2em] text-[#a28780] sm:text-[11px] sm:tracking-[0.22em]">
                  Canal complementario
                </p>
                <h3 class="mt-2 text-xl font-medium text-[#171717] sm:text-2xl">
                  Facebook
                </h3>
                <p class="mt-2 text-sm text-[#7b6760]">
                  Información y presencia institucional
                </p>
              </div>
            </div>

            <span class="rounded-full border border-[#eadfdb] px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.14em] text-[#7a6660] sm:text-[11px] sm:tracking-[0.16em]">
              Secundario
            </span>
          </div>

          <p class="mt-5 text-sm leading-relaxed text-[#5f5652] md:text-base">
            Un canal de apoyo para compartir novedades, fortalecer la presencia
            digital de la clínica y mantener una comunicación complementaria con
            nuestra comunidad.
          </p>

          <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:items-center">
            <span class="inline-flex w-full items-center justify-center rounded-full border border-[#171717] px-4 py-2 text-sm font-semibold text-[#171717] transition group-hover:bg-[#171717] group-hover:text-white sm:w-auto">
              Ver Facebook
            </span>

            <span class="text-center text-[11px] uppercase tracking-[0.16em] text-[#99847d] sm:text-left sm:text-xs">
              Presencia institucional
            </span>
          </div>
        </a>
      </div>
    </div>

    <!-- equipo -->
    <div class="mt-6 sm:mt-8">
      <div class="rounded-[28px] border border-white/80 bg-white/84 p-5 shadow-[0_14px_35px_rgba(20,20,20,0.06)] backdrop-blur sm:rounded-[34px] sm:p-6 md:rounded-[38px] md:p-8">
        <div class="grid gap-5 sm:gap-6 lg:grid-cols-[0.92fr_1.08fr] lg:items-end">
          <div class="max-w-2xl">
            <p class="text-[10px] font-semibold uppercase tracking-[0.2em] text-[#a28780] sm:text-[11px] sm:tracking-[0.22em]">
              Equipo profesional
            </p>

            <h3 class="mt-3 text-xl font-medium text-[#171717] sm:text-2xl md:text-3xl">
              Profesionales que acompañan la experiencia de la clínica
            </h3>

            <p class="mt-3 text-sm leading-relaxed text-[#5f5652] md:text-base">
              Los perfiles del equipo amplían la presencia digital de
              MaxiloDental Studio y permiten conocer más de cerca el enfoque,
              la trayectoria y el trabajo de cada profesional.
            </p>
          </div>

          <div class="flex flex-wrap gap-3 lg:justify-end">
            <a
              href={contactoData.instagramClinica}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex w-full items-center justify-center rounded-full border border-[#171717] px-5 py-3 text-sm font-semibold text-[#171717] transition hover:bg-[#171717] hover:text-white sm:w-auto"
            >
              Ir a la cuenta principal
            </a>
          </div>
        </div>

        <div class="mt-6 grid gap-4 sm:mt-8 sm:gap-6 lg:grid-cols-2">
          <!-- yessica -->
          <a
            href={contactoData.instagramYessica}
            target="_blank"
            rel="noopener noreferrer"
            class="group overflow-hidden rounded-3xl border border-[#efe6e2] bg-[#fcfbfb] transition hover:-translate-y-1 hover:bg-white sm:rounded-4xl"
          >
            <div class="grid gap-0 md:grid-cols-[0.95fr_1.05fr]">
              <div class="relative min-h-55flow-hidden sm:min-h-65">
                <img
                  src={igYessicaImg}
                  alt="Vista previa del Instagram de la Dra. Yessica"
                  class="h-full w-full object-cover object-center transition duration-500 group-hover:scale-[1.02]"
                  loading="lazy"
                />
              </div>

              <div class="p-5 md:p-6">
                <div class="flex items-start justify-between gap-4">
                  <div>
                    <p class="text-[10px] font-semibold uppercase tracking-[0.2em] text-[#a28780] sm:text-[11px] sm:tracking-[0.22em]">
                      Perfil profesional
                    </p>
                    <h4 class="mt-3 text-xl font-medium text-[#171717]">
                      Dra. Yessica
                    </h4>
                    <p class="mt-1 text-sm text-[#7b6760]">
                      @yessicafmaxilo
                    </p>
                  </div>

                  <span class="rounded-full border border-[#eadfdb] px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.14em] text-[#7a6660] sm:text-[11px] sm:tracking-[0.16em]">
                    Instagram
                  </span>
                </div>

                <div class="mt-5 space-y-3">
                  <div class="rounded-[18px] border border-[#efe6e2] bg-white px-4 py-4 sm:rounded-[20px]">
                    <p class="text-[11px] uppercase tracking-[0.18em] text-[#a28780]">
                      Área
                    </p>
                    <p class="mt-2 text-sm font-medium text-[#171717]">
                      Cirugía oral y maxilofacial
                    </p>
                  </div>

                  <p class="text-sm leading-relaxed text-[#5f5652]">
                    Un perfil que refleja experiencia clínica, criterio
                    profesional y una atención cercana, alineada con la visión
                    de la clínica.
                  </p>
                </div>

                <span class="mt-6 inline-flex w-full items-center justify-center rounded-full border border-[#171717] px-4 py-2 text-sm font-semibold text-[#171717] transition group-hover:bg-[#171717] group-hover:text-white sm:w-auto">
                  Ver perfil
                </span>
              </div>
            </div>
          </a>

          <!-- carlos -->
          <a
            href={contactoData.instagramCarlos}
            target="_blank"
            rel="noopener noreferrer"
            class="group overflow-hidden rounded-3xl border border-[#efe6e2] bg-[#fcfbfb] transition hover:-translate-y-1 hover:bg-white sm:rounded-4xl"
          >
            <div class="grid gap-0 md:grid-cols-[0.95fr_1.05fr]">
              <div class="relative min-h-55 overflow-hidden sm:min-h-65">
                <img
                  src={igCarlosImg}
                  alt="Vista previa del Instagram del Dr. Carlos Prieto"
                  class="h-full w-full object-cover object-center transition duration-500 group-hover:scale-[1.02]"
                  loading="lazy"
                />
              </div>

              <div class="p-5 md:p-6">
                <div class="flex items-start justify-between gap-4">
                  <div>
                    <p class="text-[10px] font-semibold uppercase tracking-[0.2em] text-[#a28780] sm:text-[11px] sm:tracking-[0.22em]">
                      Perfil profesional
                    </p>
                    <h4 class="mt-3 text-xl font-medium text-[#171717]">
                      Dr. Carlos Prieto
                    </h4>
                    <p class="mt-1 text-sm text-[#7b6760]">
                      @dr_carlosprieto
                    </p>
                  </div>

                  <span class="rounded-full border border-[#eadfdb] px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.14em] text-[#7a6660] sm:text-[11px] sm:tracking-[0.16em]">
                    Instagram
                  </span>
                </div>

                <div class="mt-5 space-y-3">
                  <div class="rounded-[18px] border border-[#efe6e2] bg-white px-4 py-4 sm:rounded-[20px]">
                    <p class="text-[11px] uppercase tracking-[0.18em] text-[#a28780]">
                      Área
                    </p>
                    <p class="mt-2 text-sm font-medium text-[#171717]">
                      Odontología estética e implantes
                    </p>
                  </div>

                  <p class="text-sm leading-relaxed text-[#5f5652]">
                    Un perfil enfocado en comunicar tratamientos, detalle
                    estético y una práctica profesional que acompaña la identidad
                    general de MaxiloDental Studio.
                  </p>
                </div>

                <span class="mt-6 inline-flex w-full items-center justify-center rounded-full border border-[#171717] px-4 py-2 text-sm font-semibold text-[#171717] transition group-hover:bg-[#171717] group-hover:text-white sm:w-auto">
                  Ver perfil
                </span>
              </div>
            </div>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>