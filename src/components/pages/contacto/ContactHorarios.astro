---
import { contactoData } from "../../../data/contacto";
---

<section
  id="horarios"
  class="px-4 pb-12 pt-8 sm:px-6 sm:pb-16 sm:pt-10 md:pb-20 md:pt-14 lg:px-10 lg:pb-24 lg:pt-18"
>
  <div class="mx-auto max-w-7xl">
    <div class="grid gap-4 sm:gap-6 xl:grid-cols-[0.88fr_1.12fr]">
      <div class="rounded-[28px] border border-white/80 bg-white/84 p-5 shadow-[0_14px_35px_rgba(20,20,20,0.06)] backdrop-blur sm:rounded-4xl sm:p-6 md:rounded-[36px] md:p-8">
        <p class="text-[10px] font-semibold uppercase tracking-[0.22em] text-[#a28780] sm:text-[11px] sm:tracking-[0.24em]">
          Horarios
        </p>

        <h2 class="mt-3 text-2xl font-light tracking-tight text-[#171717] sm:text-3xl md:text-4xl">
          Disponibilidad y estado actual
        </h2>

        <p class="mt-4 text-[15px] leading-relaxed text-[#5f5652] sm:text-base">
          Este bloque cierra la página con información práctica: horarios,
          correo de apoyo y estado dinámico del consultorio.
        </p>

        <div class="mt-6 rounded-[22px] border border-[#171717] bg-[#171717] p-4 text-white sm:mt-8 sm:rounded-[28px] sm:p-5">
          <p class="text-[10px] font-semibold uppercase tracking-[0.2em] text-white/45 sm:text-[11px] sm:tracking-[0.22em]">
            Estado actual
          </p>

          <div
            data-open-status
            class="mt-3 inline-flex rounded-full border border-white/15 px-4 py-2 text-sm font-semibold text-white"
          >
            Cargando horario…
          </div>

          <p data-open-detail class="mt-3 text-sm leading-relaxed text-white/70">
            Verificando disponibilidad.
          </p>
        </div>

        <div class="mt-5 rounded-[20px] border border-[#efe6e2] bg-[#fcfbfb] p-4 sm:mt-6 sm:rounded-3xl">
          <p class="text-sm font-medium text-[#171717]">Correo de apoyo</p>
          <p class="mt-2 break-all text-sm leading-relaxed text-[#5f5652]">
            {contactoData.email}
          </p>
        </div>

        <a
          href={contactoData.whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-6 inline-flex w-full items-center justify-center rounded-full bg-[#171717] px-6 py-3 text-sm font-semibold text-white transition hover:opacity-92 sm:mt-8 sm:w-auto"
        >
          Consultar por WhatsApp
        </a>
      </div>

      <div class="grid gap-3 sm:gap-4 md:grid-cols-2 xl:grid-cols-3">
        {
          contactoData.horarios.map((item) => (
            <div class="rounded-[22px] border border-white/80 bg-white/84 p-5 shadow-[0_12px_30px_rgba(20,20,20,0.06)] backdrop-blur sm:rounded-[26px] md:rounded-[30px] md:p-6">
              <p class="text-[10px] font-semibold uppercase tracking-[0.2em] text-[#a28780] sm:text-[11px] sm:tracking-[0.22em]">
                Disponibilidad
              </p>
              <h3 class="mt-3 text-lg font-medium text-[#171717] sm:text-xl">
                {item.dia}
              </h3>
              <p class="mt-3 text-sm leading-relaxed text-[#5f5652]">{item.hora}</p>
            </div>
          ))
        }

        <div class="rounded-[22px] border border-white/80 bg-white/84 p-5 shadow-[0_12px_30px_rgba(20,20,20,0.06)] backdrop-blur sm:rounded-[26px] md:col-span-2 md:rounded-[30px] md:p-6 xl:col-span-3">
          <p class="text-[10px] font-semibold uppercase tracking-[0.2em] text-[#a28780] sm:text-[11px] sm:tracking-[0.22em]">
            Cierre del recorrido
          </p>
          <h3 class="mt-3 text-xl font-medium text-[#171717] sm:text-2xl">
            Una página completa, no un solo bloque forzado
          </h3>
          <p class="mt-3 max-w-3xl text-sm leading-relaxed text-[#5f5652]">
            Separar la experiencia en secciones mejora mucho la lectura, la
            respuesta en móvil y la sensación visual general. Aquí el contacto ya
            no se ve improvisado ni cargado, sino estructurado.
          </p>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    const statusEl = document.querySelector("[data-open-status]");
    const detailEl = document.querySelector("[data-open-detail]");

    if (statusEl && detailEl) {
      const now = new Date();

      const weekdayParts = new Intl.DateTimeFormat("es-CO", {
        timeZone: "America/Bogota",
        weekday: "short",
      }).format(now);

      const timeParts = new Intl.DateTimeFormat("es-CO", {
        timeZone: "America/Bogota",
        hour: "2-digit",
        minute: "2-digit",
        hour12: false,
      }).formatToParts(now);

      const hour = Number(timeParts.find((p) => p.type === "hour")?.value ?? 0);
      const minute = Number(timeParts.find((p) => p.type === "minute")?.value ?? 0);
      const totalMinutes = hour * 60 + minute;

      const normalizedDay = weekdayParts
        .toLowerCase()
        .replace(".", "")
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "");

      const dayMap = {
        lun: 1,
        mar: 2,
        mie: 3,
        jue: 4,
        vie: 5,
        sab: 6,
        dom: 0,
      };

      const day = dayMap[normalizedDay] ?? -1;

      const openWeek = day >= 1 && day <= 5 && totalMinutes >= 480 && totalMinutes < 1080;
      const openSat = day === 6 && totalMinutes >= 480 && totalMinutes < 780;
      const sundayAgenda = day === 0;

      if (openWeek || openSat) {
        statusEl.textContent = "Abierto ahora";
        statusEl.className =
          "mt-3 inline-flex rounded-full border border-emerald-400/20 bg-emerald-400/10 px-4 py-2 text-sm font-semibold text-emerald-200";
        detailEl.textContent =
          "Estamos dentro del horario habitual de atención en Colombia.";
      } else if (sundayAgenda) {
        statusEl.textContent = "Atención bajo agenda";
        statusEl.className =
          "mt-3 inline-flex rounded-full border border-amber-400/20 bg-amber-400/10 px-4 py-2 text-sm font-semibold text-amber-100";
        detailEl.textContent =
          "Los domingos y festivos se manejan con disponibilidad bajo agenda previa.";
      } else {
        statusEl.textContent = "Cerrado ahora";
        statusEl.className =
          "mt-3 inline-flex rounded-full border border-white/15 bg-white/5 px-4 py-2 text-sm font-semibold text-white";
        detailEl.textContent =
          "Puedes escribir por WhatsApp y continuar la conversación para la siguiente franja disponible.";
      }
    }
  </script>
</section>