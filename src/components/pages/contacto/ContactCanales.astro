---
import { contactoData } from "../../../data/contacto";
---

<section id="canales" class="px-6 py-10 md:py-14 lg:px-10 lg:py-18">
  <div class="mx-auto max-w-7xl">
    <div class="mb-8 max-w-3xl">
      <p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-[#a28780]">
        Canales de contacto
      </p>
      <h2 class="mt-3 text-3xl font-light tracking-tight text-[#171717] md:text-4xl">
        Cada acceso con su propio espacio
      </h2>
      <p class="mt-3 text-base leading-relaxed text-[#5f5652]">
        En lugar de dejar todo mezclado, cada canal tiene su bloque para que la
        navegación sea más cómoda y más clara, también en móvil.
      </p>
    </div>

    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
      <a
        href={contactoData.whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="group rounded-[30px] border border-[#1b1b1b] bg-[#171717] p-6 text-white shadow-[0_20px_45px_rgba(0,0,0,0.14)] transition duration-300 hover:-translate-y-1"
      >
        <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-white/50">
          Canal principal
        </p>
        <h3 class="mt-3 text-2xl font-light">WhatsApp</h3>
        <p class="mt-3 text-sm leading-relaxed text-white/72">
          Agenda tu cita, consulta horarios y recibe orientación inmediata.
        </p>
        <span class="mt-6 inline-flex rounded-full border border-white/15 px-3 py-1 text-xs font-medium text-white/90">
          Abrir conversación
        </span>
      </a>

      <a
        href={`tel:${contactoData.phoneRaw}`}
        class="group rounded-[30px] border border-white/80 bg-white/84 p-6 shadow-[0_12px_30px_rgba(20,20,20,0.06)] backdrop-blur transition duration-300 hover:-translate-y-1"
      >
        <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-[#a28780]">
          Atención directa
        </p>
        <h3 class="mt-3 text-xl font-medium text-[#171717]">
          {contactoData.phoneDisplay}
        </h3>
        <p class="mt-3 text-sm leading-relaxed text-[#5f5652]">
          Número oficial del consultorio para contacto rápido.
        </p>
        <span class="mt-6 inline-flex rounded-full border border-[#eadfdb] px-3 py-1 text-xs font-medium text-[#7a6660]">
          Llamar ahora
        </span>
      </a>

      <a
        href={`mailto:${contactoData.email}`}
        class="group rounded-[30px] border border-white/80 bg-white/84 p-6 shadow-[0_12px_30px_rgba(20,20,20,0.06)] backdrop-blur transition duration-300 hover:-translate-y-1"
      >
        <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-[#a28780]">
          Correo
        </p>
        <h3 class="mt-3 break-all text-xl font-medium text-[#171717]">
          {contactoData.email}
        </h3>
        <p class="mt-3 text-sm leading-relaxed text-[#5f5652]">
          Canal complementario para información detallada.
        </p>
        <span class="mt-6 inline-flex rounded-full border border-[#eadfdb] px-3 py-1 text-xs font-medium text-[#7a6660]">
          Enviar correo
        </span>
      </a>

      <a
        href={contactoData.mapsUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="group rounded-[30px] border border-white/80 bg-white/84 p-6 shadow-[0_12px_30px_rgba(20,20,20,0.06)] backdrop-blur transition duration-300 hover:-translate-y-1"
      >
        <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-[#a28780]">
          Cómo llegar
        </p>
        <h3 class="mt-3 text-xl font-medium text-[#171717]">
          {contactoData.address}
        </h3>
        <p class="mt-3 text-sm leading-relaxed text-[#5f5652]">
          Abre la ruta en Google Maps y ubica el consultorio fácilmente.
        </p>
        <span class="mt-6 inline-flex rounded-full border border-[#eadfdb] px-3 py-1 text-xs font-medium text-[#7a6660]">
          Ver ubicación
        </span>
      </a>
    </div>
  </div>
</section>
